<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Frontdesk Present Students</title>
	<style>
		*{margin:0;padding:0;box-sizing:border-box}
		:root{--primary:#0b6bcb;--primary-dark:#084f98;--secondary:#1f2937;--bg:#f3f6fb;--card:#fff;--border:#d8e1ea;--text:#243444;--muted:#6b7280;--danger:#b91c1c;--row:#f8fbff}
		body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:linear-gradient(160deg,#e7eef7 0%,#f5f9ff 100%);min-height:100vh;padding:18px;color:var(--text)}
		.container{max-width:1200px;margin:0 auto}
		.header{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;box-shadow:0 2px 8px rgba(18,52,86,.08)}
		.title{font-size:22px;font-weight:800;color:var(--secondary);letter-spacing:.3px}
		.meta{margin-top:6px;font-size:14px;color:var(--muted)}
		.meta strong{color:var(--secondary)}
		.filter-bar{margin-top:14px;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;align-items:end}
		.filter-item label{display:block;font-size:12px;font-weight:700;color:var(--muted);margin-bottom:5px}
		.filter-item select,.response-input{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:8px;background:#fff;color:var(--text);font-size:13px}
		.search-btn{padding:9px 12px;border:0;border-radius:8px;background:linear-gradient(180deg,var(--primary),var(--primary-dark));color:#fff;font-weight:700;cursor:pointer}
		.search-btn:hover{filter:brightness(1.05)}
		.response-input.saving{border-color:#93c5fd;background:#eff6ff}
		.response-input.saved{border-color:#86efac;background:#f0fdf4}
		.response-input.error{border-color:#fca5a5;background:#fef2f2}
		.table-wrap{margin-top:14px;background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:auto;box-shadow:0 2px 8px rgba(18,52,86,.08)}
		table{width:100%;border-collapse:collapse;min-width:840px}
		thead th{position:sticky;top:0;background:linear-gradient(180deg,var(--primary) 0%,var(--primary-dark) 100%);color:#fff;font-size:13px;font-weight:700;padding:12px 10px;border-right:1px solid rgba(255,255,255,.2);text-align:left;white-space:nowrap}
		tbody td{font-size:14px;padding:10px;border-top:1px solid var(--border)}
		tbody tr:nth-child(even){background:var(--row)}
		tbody tr:hover{background:#eef5ff}
		.num{width:56px;text-align:center}
		.class-col,.section-col{width:90px}
		.contact-link{display:inline-block;padding:6px 10px;border-radius:999px;background:#e7f1ff;color:#0a4f94;text-decoration:none;font-weight:600;border:1px solid #bdd8ff}
		.contact-link:hover{background:#d6e9ff}
		.empty{padding:26px;text-align:center;color:var(--muted);font-weight:600}
		.no-contact{color:var(--danger);font-weight:600}
		@media (max-width: 768px){
			body{padding:10px}
			.title{font-size:18px}
			.meta{font-size:12px}
			table{min-width:760px}
		}
	</style>
</head>
<body>
	<div class="container">
		<div class="header">
			<div class="title">Today Present Students</div>
			<div class="meta">
				Date (BS): <strong><%= todayBs %></strong>
				| Academic Year: <strong><%= academicYear %></strong>
				| Month: <strong><%= currentMonthName %></strong>
				| Day: <strong><%= todayDay %></strong>
			</div>
			<form class="filter-bar" method="GET" action="/frontdesk">
				<div class="filter-item">
					<label for="academicYear">Academic Year</label>
					<select name="academicYear" id="academicYear">
						<% (academicYearOptions || []).forEach((year) => { %>
							<option value="<%= year %>" <%= String(year) === String(academicYear) ? 'selected' : '' %>><%= year %></option>
						<% }) %>
					</select>
				</div>
				<div class="filter-item">
					<label for="month">Month</label>
					<select name="month" id="month">
						<% (monthOptions || []).forEach((month) => { %>
							<option value="<%= month %>" <%= String(month) === String(currentMonthName) ? 'selected' : '' %>><%= month %></option>
						<% }) %>
					</select>
				</div>
				<div class="filter-item">
					<label for="day">Day</label>
					<select name="day" id="day">
						<% (dayOptions || []).forEach((day) => { %>
							<option value="<%= day %>" <%= Number(day) === Number(todayDay) ? 'selected' : '' %>><%= day %></option>
						<% }) %>
					</select>
				</div>
				<div class="filter-item">
					<button type="submit" class="search-btn">Find Record</button>
				</div>
			</form>
		</div>

		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th class="num">SN</th>
						<th>Present Name</th>
						<th>Contact</th>
						<th class="class-col">Class</th>
						<th class="section-col">Section</th>
						<th>Call</th>
						<th>Parent Response</th>
					</tr>
				</thead>
				<tbody>
					<% if (presentStudents && presentStudents.length > 0) { %>
						<% presentStudents.forEach((student) => { %>
							<tr>
								<td class="num"><%= student.sn %></td>
								<td><%= student.name || '-' %></td>
								<td>
									<% if (student.contact) { %>
										<%= student.contact %>
									<% } else { %>
										<span class="no-contact">No Contact</span>
									<% } %>
								</td>
								<td class="class-col"><%= student.studentClass || '-' %></td>
								<td class="section-col"><%= student.section || '-' %></td>
								<td>
									<% if (student.dialNumber) { %>
										<a class="contact-link" href="tel:<%= student.dialNumber %>">Call Now</a>
									<% } else { %>
										<span class="no-contact">Unavailable</span>
									<% } %>
								</td>
								<td>
									<input
										type="text"
										class="response-input"
										placeholder="Type parent response"
										value="<%= student.reason || '' %>"
										data-reg="<%= student.reg %>"
										data-studentclass="<%= student.studentClass %>"
										data-section="<%= student.section %>"
										data-academicyear="<%= academicYear %>"
										data-month="<%= currentMonthName %>"
										data-day="<%= todayDay %>"
									>
								</td>
							</tr>
						<% }) %>
					<% } else { %>
						<tr>
							<td colspan="7" class="empty">No present students found for today.</td>
						</tr>
					<% } %>
				</tbody>
			</table>
		</div>
	</div>

	<script>
		const reasonTimers = new Map();

		async function saveReason(inputEl) {
			const payload = {
				reg: inputEl.dataset.reg,
				studentClass: inputEl.dataset.studentclass,
				section: inputEl.dataset.section,
				academicYear: inputEl.dataset.academicyear,
				month: inputEl.dataset.month,
				day: inputEl.dataset.day,
				reason: inputEl.value
			};

			inputEl.classList.remove('saved', 'error');
			inputEl.classList.add('saving');

			try {
				const response = await fetch('/frontdesk/reason', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json'
					},
					body: JSON.stringify(payload)
				});

				if (!response.ok) {
					throw new Error('Failed to save reason');
				}

				inputEl.classList.remove('saving', 'error');
				inputEl.classList.add('saved');
			} catch (error) {
				console.error(error);
				inputEl.classList.remove('saving', 'saved');
				inputEl.classList.add('error');
			}
		}

		document.querySelectorAll('.response-input').forEach((inputEl) => {
			inputEl.addEventListener('input', () => {
				if (reasonTimers.has(inputEl)) {
					clearTimeout(reasonTimers.get(inputEl));
				}

				const timer = setTimeout(async () => {
					await saveReason(inputEl);
					reasonTimers.delete(inputEl);
				}, 600);

				reasonTimers.set(inputEl, timer);
			});
		});
	</script>
</body>
</html>
