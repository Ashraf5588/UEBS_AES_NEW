<script>
let currentGalleryImages = [];
let currentIndex = 0;

window.openGallery = function(src, allSrcs) {
    const modal = document.getElementById("galleryModal");
    const modalImg = document.getElementById("galleryImg");
    
    // Convert allSrcs to array if passed as string/other
    if (!allSrcs) allSrcs = [src];
    if (typeof allSrcs === 'string') allSrcs = [allSrcs];
    
    currentGalleryImages = allSrcs;
    currentIndex = currentGalleryImages.indexOf(src);
    if(currentIndex === -1) currentIndex = 0;
    
    modal.style.display = "block";
    modalImg.src = currentGalleryImages[currentIndex];
}

window.changeGalleryImage = function(n) {
    currentIndex += n;
    if (currentIndex >= currentGalleryImages.length) {
        currentIndex = 0;
    }
    if (currentIndex < 0) {
        currentIndex = currentGalleryImages.length - 1;
    }
    const modalImg = document.getElementById("galleryImg");
    modalImg.src = currentGalleryImages[currentIndex];
    
    // Slight flash effect
    modalImg.style.opacity = 0.5;
    setTimeout(() => { modalImg.style.opacity = 1; }, 50);
}

// Close gallery
const closeBtn = document.querySelector(".close-gallery");
if(closeBtn) {
    closeBtn.onclick = function() { 
      document.getElementById("galleryModal").style.display = "none";
    }
}

// Close on outside click
window.onclick = function(event) {
  const modal = document.getElementById("galleryModal");
  if (event.target == modal) {
    modal.style.display = "none";
  }
}

// Keyboard nav
document.addEventListener('keydown', function(event) {
    const modal = document.getElementById("galleryModal");
    if (modal && modal.style.display === "block") {
        if (event.key === "ArrowLeft") {
            changeGalleryImage(-1);
        } else if (event.key === "ArrowRight") {
            changeGalleryImage(1);
        } else if (event.key === "Escape") {
            modal.style.display = "none";
        }
    }
});
</script>
</body>
</html>
