<!-- script to calculate total obtained per input per practical/project -->
<script>
function formatTotal(total) {
  return Number.isInteger(total) ? total : total.toFixed(2);
}

function syncQuickRadioState(input) {
  const radioId = input.dataset.radioId;
  if (!radioId) return;

  const radio = document.getElementById(radioId);
  if (!radio) return;

  const entered = parseFloat(input.value);
  const defaultMark = parseFloat(input.dataset.defaultMark);

  if (Number.isNaN(entered) || Number.isNaN(defaultMark)) {
    radio.checked = false;
    return;
  }

  radio.checked = Math.abs(entered - defaultMark) < 0.001;
}

function syncPracticalHiddenValue(input) {
  const hidden = document.getElementById(input.dataset.hiddenId);
  if (!hidden) return;

  const marks = (input.value || '').trim();
  if (!marks) {
    hidden.value = '';
    syncQuickRadioState(input);
    return;
  }

  const indicator = hidden.dataset.indicator || '';
  const adhar = hidden.dataset.adhar || '';
  const outcome = hidden.dataset.outcome || '';
  hidden.value = `${marks}||${indicator}||${adhar}||${outcome}`;
  syncQuickRadioState(input);
}

function syncProjectHiddenValue(input) {
  const hidden = document.getElementById(input.dataset.hiddenId);
  if (!hidden) return;

  const marks = (input.value || '').trim();
  if (!marks) {
    hidden.value = '';
    syncQuickRadioState(input);
    return;
  }

  const indicator = hidden.dataset.indicator || '';
  const adhar = hidden.dataset.adhar || '';
  hidden.value = `${marks}||${indicator}||${adhar}`;
  syncQuickRadioState(input);
}

function updatePracticalTotal(group) {
  const totalInput = document.getElementById("practical-total-" + group);
  if (!totalInput) return;

  const inputs = document.querySelectorAll(`.marks-input[data-practical="${group}"]`);
  const total = Array.from(inputs).reduce((sum, input) => {
    return sum + (parseFloat(input.value) || 0);
  }, 0);

  totalInput.value = formatTotal(total);
}

function updateProjectTotal(group) {
  const totalInput = document.getElementById("project-total-" + group);
  if (!totalInput) return;

  const inputs = document.querySelectorAll(`.marks-input-project[data-project="${group}"]`);
  const total = Array.from(inputs).reduce((sum, input) => {
    return sum + (parseFloat(input.value) || 0);
  }, 0);

  totalInput.value = formatTotal(total);
}

document.querySelectorAll(".marks-input").forEach(input => {
  input.addEventListener("input", e => {
    const group = e.target.dataset.practical;
    syncPracticalHiddenValue(e.target);
    updatePracticalTotal(group);
  });
});

document.querySelectorAll(".marks-input-project").forEach(input => {
  input.addEventListener("input", e => {
    const group = e.target.dataset.project;
    syncProjectHiddenValue(e.target);
    updateProjectTotal(group);
  });
});

document.querySelectorAll(".marks-radio-quick").forEach(radio => {
  radio.addEventListener("change", e => {
    const input = document.getElementById(e.target.dataset.targetId);
    if (!input) return;
    input.value = e.target.dataset.defaultMark || '';
    syncPracticalHiddenValue(input);
    updatePracticalTotal(e.target.dataset.practical);
  });
});

document.querySelectorAll(".marks-radio-project-quick").forEach(radio => {
  radio.addEventListener("change", e => {
    const input = document.getElementById(e.target.dataset.targetId);
    if (!input) return;
    input.value = e.target.dataset.defaultMark || '';
    syncProjectHiddenValue(input);
    updateProjectTotal(e.target.dataset.project);
  });
});
</script>




