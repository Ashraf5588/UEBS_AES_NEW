<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lesson Form</title>
  <style>
    :root {
      --orange: #f58a1f;
      --orange-dark: #c6630a;
      --blue: #1b3a68;
      --blue-dark: #122747;
      --text: #1e293b;
      --muted: #5b6777;
      --card: #ffffff;
      --border: #e1e7ef;
      --shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
      --bg: radial-gradient(circle at top left, rgba(245, 138, 31, 0.18), transparent 35%),
            radial-gradient(circle at top right, rgba(27, 58, 104, 0.2), transparent 30%),
            linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      background: var(--bg);
      font-family: "Lexend", "Segoe UI", sans-serif;
      color: var(--text);
    }

    .page {
      width: min(520px, 100%);
      background: var(--card);
      border-radius: 20px;
      padding: 28px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(27, 58, 104, 0.12);
    }

    .title {
      margin: 0 0 8px;
      font-size: 24px;
      font-weight: 700;
      color: var(--blue-dark);
    }

    .subtitle {
      margin: 0 0 22px;
      color: var(--muted);
      font-size: 14px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 18px;
    }

    label {
      font-weight: 600;
      color: var(--blue);
    }

    select {
      padding: 12px 14px;
      border: 1px solid var(--border);
      border-radius: 12px;
      font-size: 15px;
      background: #fff;
      color: var(--text);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    select:focus {
      outline: none;
      border-color: rgba(27, 58, 104, 0.6);
      box-shadow: 0 0 0 3px rgba(27, 58, 104, 0.18);
    }

    .primary-btn {
      width: 100%;
      border: none;
      background: linear-gradient(135deg, var(--orange) 0%, var(--orange-dark) 100%);
      color: #fff;
      padding: 12px 16px;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 12px 20px rgba(245, 138, 31, 0.24);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .primary-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 16px 24px rgba(245, 138, 31, 0.28);
    }

    .accent-bar {
      height: 6px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--blue) 0%, var(--orange) 100%);
      margin-bottom: 18px;
    }

    @media (max-width: 540px) {
      .page {
        padding: 22px;
        border-radius: 18px;
      }

      .title {
        font-size: 21px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="accent-bar"></div>
    <h1 class="title">Lesson Plan Selector</h1>
    <p class="subtitle">Choose the class and subject to open the lesson plan form.</p>

    <div class="field">
      <label for="class">Class</label>
      <select id="class" name="class">
        <% const classOptions = [...new Set((sidenavData.studentClassdata || []).map((cls) => cls.studentClass).filter(Boolean))]; %>
        <% classOptions.forEach(cls => { %>
          <option value="<%= cls %>"><%= cls %></option>
        <% }) %>
      </select>
    </div>

    <div class="field">
      <label for="subject">Subject</label>
      <select id="subject" name="subject">
        <% const subjectOptions = [...new Set((sidenavData.subjects || []).map((subj) => subj.newsubject).filter(Boolean))]; %>
        <% subjectOptions.forEach(subj => { %>
          <option value="<%= subj %>"><%= subj %></option>
        <% }) %>
      </select>
    </div>

    <button type="button" class="primary-btn" onclick="loadLessonPlan()">Load Lesson Plan</button>
  </div>

<script>
  function loadLessonPlan() {
    const selectedClass = document.getElementById('class').value;
    const selectedSubject = document.getElementById('subject').value;

    if (!selectedClass || !selectedSubject) {
      alert('Please select both class and subject.');
      return;
    }

    // Redirect to the lesson plan form with query parameters
    window.location.href = `/annualform?studentClass=${encodeURIComponent(selectedClass)}&subject=${encodeURIComponent(selectedSubject)}`;
  }
</script>
</body>
</html>