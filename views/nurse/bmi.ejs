<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Health Management - BMI Update</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/health-record.css">
</head>
<body class="hm-body">
  <button class="hm-menu-toggle" type="button" aria-controls="hmSidebar" aria-expanded="false">Menu</button>
  <div class="hm-backdrop" id="hmBackdrop" hidden></div>
  <div class="hm-shell">
    <aside class="hm-sidenav" id="hmSidebar" aria-label="Nurse tools navigation">
      <div class="hm-sidenav-header">
        <div>
          <p class="hm-sidenav-kicker">Nurse Tools</p>
          <h2>Health Module</h2>
        </div>
        <button class="hm-sidenav-close" type="button" aria-label="Close menu">×</button>
      </div>
      <nav class="hm-sidenav-nav">
        <a href="/healthrecord" class="hm-nav-link">Dashboard</a>
        <a href="/healthrecord/bmi" class="hm-nav-link">Add height, weight and MUAQ</a>
        <a href="/healthrecord/medicine" class="hm-nav-link">Add medicine name</a>
        <a href="/healthrecord/medicine/distributed" class="hm-nav-link">Add medicine distributed record</a>
        <a href="/healthrecord/padrecord" class="hm-nav-link">Add pad record</a>
        <a href="/healthrecord/analytics" class="hm-nav-link">Generate analytics</a>
      </nav>
    </aside>

    <div class="hm-main-wrap">
      <div class="hm-bg"></div>
      <div class="hm-page">
        <header class="hm-hero">
          <div>
            <p class="hm-kicker">School Health</p>
            <h1>Height, Weight and MUAQ</h1>
            <p class="hm-sub">Choose a class and section, load students, enter height in feet and inches, and save the calculated BMI back to student records.</p>
          </div>
          <div class="hm-badge">
            <span>Clinic</span>
            <strong>BMI Update</strong>
          </div>
        </header>

        <section class="hm-card hm-bmi-panel">
          <div class="hm-card-header">
            <h2>Select Group</h2>
            <span class="hm-muted">Grouped by class and section</span>
          </div>

          <div class="hm-bmi-filters">
            <label class="hm-field">
              <span>Class / Section</span>
              <select id="bmiGroupSelect"></select>
            </label>

            <label class="hm-field">
              <span>Academic Year</span>
              <select id="bmiYearSelect"></select>
            </label>

            <button type="button" class="hm-button" id="loadBmiBtn">Load Students</button>
          </div>
        </section>

        <section class="hm-card hm-bmi-table-card">
          <div class="hm-card-header hm-records-header">
            <h2>Student BMI Table</h2>
            <span class="hm-muted" id="bmiStatus">Select a group to load students.</span>
          </div>

          <div class="hm-table-wrap">
            <table class="hm-table hm-bmi-table" id="bmiTable">
              <thead>
                <tr>
                  <th>Roll</th>
                  <th>Name</th>
                  <th>DOB</th>
                  <th>Age</th>
                  <th>Height Ft</th>
                  <th>Height In</th>
                  <th>Weight</th>
                  <th>MUAQ</th>
                  <th>BMI</th>
                </tr>
              </thead>
              <tbody id="bmiTableBody">
                <tr><td colspan="9" class="hm-empty">No students loaded yet.</td></tr>
              </tbody>
            </table>
          </div>

          <div class="hm-actions hm-bmi-actions">
            <button type="button" class="hm-button" id="saveBmiBtn">Save BMI</button>
          </div>
        </section>
      </div>
    </div>
  </div>

  <script src="/nurse-bmi.js"></script>
</body>
</html>
