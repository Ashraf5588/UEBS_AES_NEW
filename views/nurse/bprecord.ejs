<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Health Management - Blood Pressure</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/health-record.css">
</head>
<body class="hm-body">
	<button class="hm-menu-toggle" type="button" aria-controls="hmSidebar" aria-expanded="false">Menu</button>
	<div class="hm-backdrop" id="hmBackdrop" hidden></div>
	<div class="hm-shell">
		<aside class="hm-sidenav" id="hmSidebar" aria-label="Nurse tools navigation">
			<div class="hm-sidenav-header">
				<div>
					<p class="hm-sidenav-kicker">Nurse Tools</p>
					<h2>Health Module</h2>
				</div>
				<button class="hm-sidenav-close" type="button" aria-label="Close menu">×</button>
			</div>
			<nav class="hm-sidenav-nav">
				<a href="/healthrecord" class="hm-nav-link">Dashboard</a>
				<a href="/healthrecord/bmi" class="hm-nav-link">Add height, weight and MUAQ</a>
				<a href="/healthrecord/bp/add" class="hm-nav-link">Add blood pressure</a>
				<a href="/healthrecord/medicine" class="hm-nav-link">Add medicine name</a>
				<a href="/healthrecord/medicine/distributed" class="hm-nav-link">Add medicine distributed record</a>
				<a href="/healthrecord/padrecord" class="hm-nav-link">Add pad record</a>
				<a href="/healthrecord/analytics" class="hm-nav-link">Generate analytics</a>
			</nav>
		</aside>

		<div class="hm-main-wrap">
			<div class="hm-bg"></div>
			<div class="hm-page">
				<header class="hm-hero">
					<div>
						<p class="hm-kicker">School Health</p>
						<h1>Staff Blood Pressure</h1>
						<p class="hm-sub">Upload a CSV of staff names, then record blood pressure values in the table below. Changes autosave when you press Enter.</p>
					</div>
					<div class="hm-badge">
						<span>Clinic</span>
						<strong>BP Record</strong>
					</div>
				</header>

				<section class="hm-card hm-bmi-panel">
					<div class="hm-card-header">
						<h2>Upload Staff List</h2>
						<span class="hm-muted">CSV with a staff name column</span>
					</div>

					<form class="hm-bmi-filters" action="/healthrecord/bp/staff/upload" method="post" enctype="multipart/form-data">
						<label class="hm-field">
							<span>Staff CSV</span>
							<input type="file" name="staffCsv" accept=".csv" required>
						</label>

						<button type="submit" class="hm-button">Upload Staff Names</button>
					</form>
				</section>

				<section class="hm-card hm-bmi-table-card">
					<div class="hm-card-header hm-records-header">
						<h2>Staff BP Table</h2>
						<span class="hm-muted" id="bpStatus"><%= initialStatus || '' %></span>
					</div>

					<div class="hm-table-wrap">
						<table class="hm-table hm-bmi-table" id="bpTable">
							<thead>
								<tr>
									<th>SN</th>
									<th>Staff Name</th>
									<th>Blood Pressure</th>
								</tr>
							</thead>
							<tbody id="bpTableBody">
								<tr><td colspan="3" class="hm-empty">Loading staff list...</td></tr>
							</tbody>
						</table>
					</div>

					<div class="hm-actions hm-bmi-actions">
						<button type="button" class="hm-button" id="saveBpBtn">Save Blood Pressure</button>
					</div>
				</section>
			</div>
		</div>
	</div>

	<script src="/nurse-bprecord.js"></script>
</body>
</html>
