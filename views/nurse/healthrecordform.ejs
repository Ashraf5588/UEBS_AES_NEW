<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Health Management - Student Record</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/health-record.css">
</head>
<body class="hm-body">
  <button class="hm-menu-toggle" type="button" aria-controls="hmSidebar" aria-expanded="false">Menu</button>
  <div class="hm-backdrop" id="hmBackdrop" hidden></div>
  <div class="hm-shell">
    <aside class="hm-sidenav" id="hmSidebar" aria-label="Nurse tools navigation">
      <div class="hm-sidenav-header">
        <div>
          <p class="hm-sidenav-kicker">Nurse Tools</p>
          <h2>Health Module</h2>
        </div>
        <button class="hm-sidenav-close" type="button" aria-label="Close menu">×</button>
      </div>
      <nav class="hm-sidenav-nav">
        <a href="/healthrecord" class="hm-nav-link">Dashboard</a>
        <a href="/healthrecord/bmi" class="hm-nav-link">Add height, weight and MUAQ</a>
        <a href="/healthrecord/medicine" class="hm-nav-link">Add medicine name</a>
        <a href="/healthrecord/medicine/distributed" class="hm-nav-link">Add medicine distributed record</a>
          <a href="/healthrecord/analytics" class="hm-nav-link">Generate analytics</a>
          <a href="/healthrecord/padrecord" class="hm-nav-link">Add pad record</a>
      </nav>
    </aside>
    <div class="hm-main-wrap">
  <div class="hm-bg"></div>
  <div class="hm-page">
    <header class="hm-hero">
      <div>
        <p class="hm-kicker">School Health</p>
        <h1>Student Health Record</h1>
        <p class="hm-sub">Search a student, review details, and log a clinical visit in one place.</p>
      </div>
      <div class="hm-badge">
        <span>Clinic</span>
        <strong>Active Intake</strong>
      </div>
    </header>

    <section class="hm-grid">
      <form id="healthRecordForm" class="hm-card hm-form" action="/healthrecord" method="POST" autocomplete="off">
        <div class="hm-card-header">
          <h2>Student Lookup</h2>
          <span class="hm-muted">Type at least 2 letters</span>
        </div>

        <label class="hm-field">
          <span>Student Name</span>
          <input id="studentSearch" name="studentSearch" type="text" placeholder="Search student" required>
          <div id="studentSuggestions" class="hm-suggestions"></div>
        </label>

        <div class="hm-summary" id="studentSummary">
          <p class="hm-muted">No student selected yet.</p>
        </div>

        <div class="hm-divider"></div>

        <div class="hm-form-grid">
          <label class="hm-field">
            <span>Diagnosis</span>
            <input name="diagnosis" type="text" placeholder="Primary diagnosis" required>
          </label>

          <label class="hm-field">
            <span>Treatment Plan</span>
            <textarea name="treatment" rows="4" placeholder="Medication, procedures, advice" required></textarea>
          </label>
        </div>

        <label class="hm-field">
          <span>Remarks</span>
          <textarea name="remarks" rows="3" placeholder="Follow-up notes"></textarea>
        </label>

        <input type="hidden" name="reg" id="reg">
        <input type="hidden" name="name" id="name">
        <input type="hidden" name="studentClass" id="studentClass">
        <input type="hidden" name="section" id="section">
        <input type="hidden" name="roll" id="roll">
        <input type="hidden" name="fatherName" id="fatherName">
        <input type="hidden" name="address" id="address">

        <button type="submit" class="hm-button">Save Health Record</button>
        <p id="formStatus" class="hm-status" aria-live="polite"></p>
      </form>

  
    </section>

    <section class="hm-card hm-records">
      <div class="hm-card-header hm-records-header">
        <h2>Saved Records</h2>
        <span class="hm-muted">Default: All</span>
      </div>

      <div class="hm-record-filters">
        <label class="hm-field hm-inline-field">
          <span>Range</span>
          <select id="recordRange">
            <option value="all" selected>All</option>
            <option value="today">Today</option>
            <option value="last7">Last 7 Days</option>
            <option value="lastMonth">Last Month</option>
            <option value="thisYear">This Year</option>
          </select>
        </label>

        <label class="hm-field hm-inline-field">
          <span>Specific Date</span>
          <input type="date" id="recordDate" />
        </label>

        <button type="button" class="hm-button" id="recordFilterBtn">Find Records</button>
      </div>

      <div class="hm-table-wrap">
        <table class="hm-table" id="recordsTable">
          <thead>
            <tr>
              <th>SN</th>
              <th>Date</th>
              <th>Student</th>
              <th>Class</th>
              <th>Diagnosis</th>
              <th>Treatment</th>
              <th>Remarks</th>
              <th>Contact</th>
              <th>Call</th>
            </tr>
          </thead>
          <tbody id="recordsTableBody">
            <tr><td colspan="9" class="hm-empty">Loading records...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>
  </div>
  </div>
  <script src="/health-record.js"></script>
</body>
</html>