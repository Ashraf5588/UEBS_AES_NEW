<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Health Management - Medicine Name</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/health-record.css">
</head>
<body class="hm-body">
  <button class="hm-menu-toggle" type="button" aria-controls="hmSidebar" aria-expanded="false">Menu</button>
  <div class="hm-backdrop" id="hmBackdrop" hidden></div>
  <div class="hm-shell">
    <aside class="hm-sidenav" id="hmSidebar" aria-label="Nurse tools navigation">
      <div class="hm-sidenav-header">
        <div>
          <p class="hm-sidenav-kicker">Nurse Tools</p>
          <h2>Health Module</h2>
        </div>
        <button class="hm-sidenav-close" type="button" aria-label="Close menu">×</button>
      </div>
      <nav class="hm-sidenav-nav">
        <a href="/healthrecord" class="hm-nav-link">Dashboard</a>
        <a href="/healthrecord/bmi" class="hm-nav-link">Add height, weight and MUAQ</a>
        <a href="/healthrecord/medicine" class="hm-nav-link">Add medicine name</a>
        <a href="/healthrecord/medicine/distributed" class="hm-nav-link">Add medicine distributed record</a>
        <a href="/healthrecord/padrecord" class="hm-nav-link">Add pad record</a>
        <a href="/healthrecord/analytics" class="hm-nav-link">Generate analytics</a>
      </nav>
    </aside>

    <div class="hm-main-wrap">
      <div class="hm-bg"></div>
      <div class="hm-page">
        <header class="hm-hero">
          <div>
            <p class="hm-kicker">School Health</p>
            <h1>Medicine Register</h1>
            <p class="hm-sub">Add medicine names for the school health desk and review the saved list in one place.</p>
          </div>
          <div class="hm-badge">
            <span>Clinic</span>
            <strong>Medicine Setup</strong>
          </div>
        </header>

        <section class="hm-grid">
          <form id="medicineForm" class="hm-card hm-form" action="/healthrecord/medicine" method="post" autocomplete="off">
            <div class="hm-card-header">
              <h2>Add Medicine Name</h2>
              <span class="hm-muted">One medicine per entry</span>
            </div>

            <label class="hm-field">
              <span>Medicine Name</span>
              <input id="medicineName" name="medicineName" type="text" placeholder="Enter medicine name" required>
            </label>

            <input type="hidden" id="medicineId" name="medicineId">

            <div class="hm-actions hm-medicine-actions">
              <button type="submit" class="hm-button" id="medicineSubmitBtn">Save Medicine</button>
              <button type="button" class="hm-button hm-button-secondary" id="medicineCancelBtn" hidden>Cancel Edit</button>
            </div>
            <p id="medicineStatus" class="hm-status" aria-live="polite"></p>
          </form>

          <section class="hm-card hm-records">
            <div class="hm-card-header hm-records-header">
              <h2>Saved Medicines</h2>
              <span class="hm-muted">Latest entries first</span>
            </div>

            <div class="hm-table-wrap">
              <table class="hm-table" id="medicineTable">
                <thead>
                  <tr>
                    <th>SN</th>
                    <th>Medicine Name</th>
                    <th>Added On</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="medicineTableBody">
                  <tr><td colspan="4" class="hm-empty">Loading medicines...</td></tr>
                </tbody>
              </table>
            </div>
          </section>
        </section>
      </div>
    </div>
  </div>

  <script src="/nurse-medicine.js"></script>
</body>
</html>