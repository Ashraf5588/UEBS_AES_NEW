<div class="modern-subject-container">
    <div class="section-header">
      <h2 class="subject-title-modern">Subject <span>List</span></h2>
    </div>

  <div class="modern-table-card">
    <div class="table-responsive">
    <table class="modern-table">
      <%
      // Define the order you want
      const orderedKeys = ['subject', 'forClass','forTerminal'];
      
      // Dynamically find all numeric keys (Questions) from the data
      const numericKeys = new Set();
      if(typeof subjectsformat !== 'undefined' && subjectsformat) {
          subjectsformat.forEach(sub => {
              Object.keys(sub).forEach(k => {
                  if(!isNaN(parseInt(k))) {
                      numericKeys.add(parseInt(k));
                  }
              });
          });
      }
      
      // Sort numeric keys 1, 2, 3...
      const sortedNumericKeys = Array.from(numericKeys).sort((a,b) => a - b).map(String);
      
      // Combine: Subject, Class, 1, 2, 3...
      const allKeys = [...orderedKeys, ...sortedNumericKeys];
      %>

      <thead>
        <tr>
          <th>Question Paper</th>
          <% allKeys.forEach((key) => { %>
            <% if (!isNaN(parseInt(key))) { %>
              <th>Q.No. <%= key %></th>
            <% } else { %>
              <th><%= key.charAt(0).toUpperCase() + key.slice(1) %></th>
            <% } %>
          <% }); %>
          
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% 
          // Sort by subject (alphabetically), then by forClass (numerically)
          const sortedSubjects = subjectsformat.slice().sort((a, b) => {
            if (a.subject < b.subject) return -1;
            if (a.subject > b.subject) return 1;
            return (parseInt(a.forClass) || 0) - (parseInt(b.forClass) || 0);
          });
          
          if(sortedSubjects.length > 0) {
              sortedSubjects.forEach((sub) => { %>
              <tr>
                  <td>
                  <% if (sub.questionPaperOfClass && sub.questionPaperOfClass !== 'default.pdf') { %>
                    <a href="/file-viewer/<%= sub.questionPaperOfClass %>" target="_blank" class="file-badge has-file" style="text-decoration:none;">
                      <i class="fas fa-file-pdf"></i> View Paper
                    </a>
                  <% } else { %>
                    <span class="file-badge">No file</span>
                  <% } %>
                </td>

                <% allKeys.forEach((key) => { %>
                  <% if (!isNaN(parseInt(key))) { %>
                    <!-- Question Column with Dropdown -->
                    <td>
                        <% if (sub.availableChapters && sub.availableChapters.length > 0) { %>
                           <select class="form-select form-select-sm chapter-select">
                               <option value="">-- Mark/Chapter --</option>
                               <!-- Show current value as an option if not in chapters list, to preserve data like '5' marks -->
                               <% if(sub[key] && !sub.availableChapters.includes(sub[key])) { %>
                                   <option value="<%= sub[key] %>" selected><%= sub[key] %></option>
                               <% } %>
                               
                               <% sub.availableChapters.forEach(chapter => { %>
                                   <option <%= sub[key] == chapter ? 'selected' : '' %> ><%= chapter %></option>
                               <% }) %>
                           </select>
                        <% } else { %>
                           <span style="font-weight: 500; color: var(--text-main);">
                               <%= (typeof sub[key] !== 'undefined' && sub[key] !== null && sub[key] !== '') ? sub[key] : '' %>
                           </span>
                        <% } %>
                    </td>
                  <% } else { %>
                    <td>
                        <span style="font-weight: 500; color: var(--text-main);">
                            <%= (typeof sub[key] !== 'undefined' && sub[key] !== null && sub[key] !== '') ? sub[key] : '' %>
                        </span>
                    </td>
                  <% } %>
                <% }); %>
              
                <td>
                  <div class="action-buttons">
                      <a href="/admin/editsub/<%= sub._id %>?editing=true&subjectname=<%= encodeURIComponent(sub.subject) %>&forClass=<%= encodeURIComponent(sub.forClass) %>&forTerminal=<%= encodeURIComponent(sub.forTerminal) %>" class="btn-icon btn-edit" title="Edit">
                        <i class="fas fa-pen"></i>
                      </a>
                    
                      <a
                        href="/delete/subject/<%= sub._id %>/<%= sub.subject %>"
                        onclick="return confirm('Are you sure you want to delete <%= sub.subject %> subject?')"
                        class="btn-icon btn-delete" title="Delete">
                        <i class="fas fa-trash-alt"></i>
                      </a>
                  </div>
                </td>

              </tr>
            <% }); 
          } else { %>
            <tr>
              <td colspan="<%= allKeys.length + 2 %>">
                 <div class="empty-state">No subjects found. Add a subject to get started.</div>
              </td>
            </tr>
          <% } %>
      </tbody>
    </table>
    </div>
  </div>
</div>

<hr><hr><br>


<script>
  const subjectInput = document.getElementById('subject');
  const classInput = document.getElementById('studentclass');
  const terminalInput = document.getElementById('forTerminal');

  async function checkSubjectExists() {
    const subject = subjectInput.value.trim();
    const studentClass = classInput.value;
    const forTerminal = terminalInput.value;

    if (subject && studentClass && forTerminal) {
      try {
        const res = await fetch(`/checksubjectexist?subjectinput=${encodeURIComponent(subject)}&forClass=${encodeURIComponent(studentClass)}&forTerminal=${encodeURIComponent(forTerminal)}`);
        const data = await res.json();
        console.log("Subject existence check data:", data);

        if (data.exists) {
          alert(`Subject ${subject} for class ${studentClass} already exists!`);
          window.location.href = '/admin/subject';
        }
      } catch (err) {
        console.error('Error checking subject:', err);
      }
    }
  }

  subjectInput.addEventListener('change', checkSubjectExists);
  classInput.addEventListener('change', checkSubjectExists);
</script>


