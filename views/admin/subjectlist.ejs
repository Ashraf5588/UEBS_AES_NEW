function generateDynamicForm(number) {
    const subContainer = document.getElementById("subQuestionContainer");
    subContainer.innerHTML = "";

    if (isNaN(number) || number <= 0) {
      subContainer.innerHTML = '<div style="color: red; margin-top: 10px;">Please enter a valid maximum question number</div>';
      return;
    }

    console.log("Generating input fields for", number, "questions");
    console.log("Edit mode:", editing);
    if (editing === 'true') {
      console.log("Subject edit data:", subjectedit);
    }

    for (let i = 1; i <= number; i++) {
      // Create question container for better organization
      const questionContainer = document.createElement("div");
      questionContainer.className = "question-container";
      questionContainer.id = `question_${i}_container`;

      // Question number heading for better clarity
      const qHeading = document.createElement("h4");
      qHeading.textContent = `Question ${i}`;
      qHeading.className = "question-heading";
      qHeading.style.marginTop = "20px";
      qHeading.style.marginBottom = "10px";
      qHeading.style.color = "#0d6efd";
      qHeading.style.borderBottom = "1px solid #dee2e6";
      qHeading.style.paddingBottom = "5px";
      questionContainer.appendChild(qHeading);
      //select chapter
     const chapterSelect = createChapterSelect({
  name: `q${i}_chapter`,
  chapters: availableChapters,
  id: `q${i}_chapter`,
  value: (typeof editing !== 'undefined' && editing === 'true' && typeof subjectedit !== 'undefined' && subjectedit[`q${i}_chapter`]) ? subjectedit[`q${i}_chapter`] : ""
});


questionContainer.appendChild(chapterSelect);

      // Create a responsive row for the main inputs using Bootstrap grid
      const inputRow = document.createElement("div");
      inputRow.className = "row g-3 mb-3";


      // First column - sub-question count
      const countColumn = document.createElement("div");
      countColumn.className = "col-12 col-sm-6";

      const countFormGroup = document.createElement("div");
      countFormGroup.className = "form-group";

      const countLabel = document.createElement("label");
      countLabel.textContent = `Total Sub-Questions in Q${i}:`;
      countLabel.className = "form-label";
      countLabel.setAttribute("for", `subQuestion${i}`);
      countFormGroup.appendChild(countLabel);

      const input = document.createElement("input");
      input.type = "number";
      input.name = `q${i}_subcount`;
      input.id = `subQuestion${i}`;
      input.required = true;
      input.placeholder = `Number of sub-questions`;
      input.className = "form-control sub-input";
      input.min = "1";
      input.dataset.questionNumber = i;
      
      countFormGroup.appendChild(input);
      countColumn.appendChild(countFormGroup);

      // Second column - mark per sub-question
      const markColumn = document.createElement("div");
      markColumn.className = "col-12 col-sm-6";

      const markFormGroup = document.createElement("div");
      markFormGroup.className = "form-group";

      const markLabel = document.createElement("label");
      markLabel.textContent = `Marks per sub-question:`;
      markLabel.className = "form-label";
      markLabel.setAttribute("for", `markPerSubQ${i}`);
      markFormGroup.appendChild(markLabel);

      const markInput = document.createElement("input");
      markInput.type = "number";
      markInput.name = `q${i}_marks_per_sub`;
      markInput.id = `markPerSubQ${i}`;
      markInput.placeholder = "Marks per sub-question";
      markInput.className = "form-control mark-per-sub-input";
      markInput.min = "0";
      markInput.step = "0.5";
      
      markFormGroup.appendChild(markInput);
      markColumn.appendChild(markFormGroup);

      // Add columns to the row
      inputRow.appendChild(countColumn);
      inputRow.appendChild(markColumn);
      questionContainer.appendChild(inputRow);
      
      // Container for sub-questions display
      const subQuestionsContainer = document.createElement("div");
      subQuestionsContainer.id = `subQuestions_${i}_container`;
      subQuestionsContainer.className = "sub-questions-container mt-3";
      questionContainer.appendChild(subQuestionsContainer);
      
      // Add event listeners to generate sub-questions
      input.addEventListener('input', function() {
        generateSubQuestions(i, this.value, markInput.value);
      });
      
      markInput.addEventListener('input', function() {
        if (input.value > 0) {
          generateSubQuestions(i, input.value, this.value);
        }
      });

      // SET EXISTING VALUES IN EDIT MODE - AFTER CREATING THE ELEMENTS
      if (editing === 'true' && typeof subjectedit !== 'undefined') {
        console.log(`Checking edit data for Q${i}:`);
        console.log(`q${i}_subcount:`, subjectedit[`q${i}_subcount`]);
        console.log(`q${i}_marks_per_sub:`, subjectedit[`q${i}_marks_per_sub`]);
        
        // Set sub-question count if it exists
        if (subjectedit[`q${i}_subcount`]) {
          input.value = subjectedit[`q${i}_subcount`];
          console.log(`Set subQuestion${i} to:`, subjectedit[`q${i}_subcount`]);
        }
        
        // Set marks per sub-question if it exists
        if (subjectedit[`q${i}_marks_per_sub`]) {
          markInput.value = subjectedit[`q${i}_marks_per_sub`];
          console.log(`Set markPerSubQ${i} to:`, subjectedit[`q${i}_marks_per_sub`]);
        }
        
        // Generate sub-questions if both values exist
        if (input.value && markInput.value) {
          console.log(`Generating sub-questions for Q${i} with count: ${input.value}, marks: ${markInput.value}`);
          // Use setTimeout to ensure the elements are fully rendered
          setTimeout(() => {
            generateSubQuestions(i, input.value, markInput.value);
            // Populate additional sub-question data after generation
            populateSubQuestionEditData(i, input.value);
          }, 100);
        }
      }

      subContainer.appendChild(questionContainer);
    }
}

// Add this new function to populate edit data for sub-questions
function populateSubQuestionEditData(questionNum, subCount) {
  if (editing !== 'true' || !subjectedit) return;
  
  console.log(`Populating sub-question edit data for Q${questionNum}`);
  
  for (let j = 1; j <= subCount; j++) {
    const letter = String.fromCharCode(96 + j); // a, b, c, etc.
    const subQuestionKey = `q${questionNum}${letter}`;
    
    // Set the main marks for the sub-question
    setTimeout(() => {
      const marksInput = document.querySelector(`input[name="${subQuestionKey}"]`);
      if (marksInput && subjectedit[subQuestionKey]) {
        marksInput.value = subjectedit[subQuestionKey];
        console.log(`Set ${subQuestionKey} marks to:`, subjectedit[subQuestionKey]);
      }
      
      // Check if this sub-question has sub-parts
      const hasSubPartsKey = `${subQuestionKey}_has_subparts`;
      const subPartsCountKey = `${subQuestionKey}_subparts_count`;
      const subPartsMarksKey = `${subQuestionKey}_marks_per_subpart`;
      
      if (subjectedit[hasSubPartsKey]) {
        console.log(`Found sub-parts for ${subQuestionKey}`);
        
        // Check the "has sub-parts" checkbox
        const checkbox = document.getElementById(`hasSubParts_${questionNum}_${letter}`);
        if (checkbox) {
          checkbox.checked = true;
          checkbox.dispatchEvent(new Event('change'));
          
          // Set sub-parts count and marks
          setTimeout(() => {
            const subPartsCountInput = document.querySelector(`input[name="${subPartsCountKey}"]`);
            const subPartsMarksInput = document.querySelector(`input[name="${subPartsMarksKey}"]`);
            
            if (subPartsCountInput && subjectedit[subPartsCountKey]) {
              subPartsCountInput.value = subjectedit[subPartsCountKey];
              console.log(`Set ${subPartsCountKey} to:`, subjectedit[subPartsCountKey]);
            }
            
            if (subPartsMarksInput && subjectedit[subPartsMarksKey]) {
              subPartsMarksInput.value = subjectedit[subPartsMarksKey];
              console.log(`Set ${subPartsMarksKey} to:`, subjectedit[subPartsMarksKey]);
              
              // Generate sub-parts
              if (subPartsCountInput && subPartsCountInput.value) {
                subPartsCountInput.dispatchEvent(new Event('change'));
                
                // Populate individual sub-part marks
                setTimeout(() => {
                  populateSubPartEditMarks(questionNum, letter, parseInt(subPartsCountInput.value));
                }, 200);
              }
            }
          }, 150);
        }
      }
    }, 150);
  }
}

// Add this function to populate individual sub-part marks
function populateSubPartEditMarks(questionNum, letter, subPartsCount) {
  if (editing !== 'true' || !subjectedit) return;
  
  console.log(`Populating sub-part marks for Q${questionNum}${letter}`);
  
  const toRoman = (num) => {
    const romanNumerals = ['i', 'ii', 'iii', 'iv', 'v', 'vi', 'vii', 'viii', 'ix', 'x', 'xi', 'xii', 'xiii', 'xiv', 'xv', 'xvi', 'xvii', 'xviii', 'xix', 'xx'];
    return romanNumerals[num - 1] || num;
  };
  
  for (let k = 1; k <= subPartsCount; k++) {
    const romanNumeral = toRoman(k);
    const subPartKey = `q${questionNum}${letter}_${romanNumeral}`;
    
    setTimeout(() => {
      const subPartInput = document.querySelector(`input[name="q${questionNum}${letter}.${romanNumeral}"]`);
      
      if (subPartInput && subjectedit[subPartKey]) {
        subPartInput.value = subjectedit[subPartKey];
        console.log(`Set ${subPartKey} marks to:`, subjectedit[subPartKey]);
      }
    }, 100);
  }
}
</script>

