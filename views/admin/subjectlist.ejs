<script>
// Function to fetch and autofill data from another class
async function autofillFromClass(classNameParam, terminalParam) {
  try {
    // Make sure we have a valid class name
    const className = classNameParam;
    console.log("autofillFromClass called with className:", className, "terminal:", terminalParam);

    if (!className) {
      alert('Please select a valid class');
      return;
    }

    const subjectName = document.getElementById('subject').value;

    if (!subjectName) {
      alert('Please enter a subject name first');
      return;
    }

    // Determine which terminal to query
    // If terminalParam is passed, use it (Cross-Terminal Copy)
    // Else use the current form's terminal (Cross-Class Copy, assuming same terminal context or default)
    let terminalToQuery = terminalParam;
    if (!terminalToQuery) {
        terminalToQuery = document.querySelector('select[name="forTerminal"]').value;
    }

    console.log("Fetching data for Class:", className, "Subject:", subjectName, "Terminal:", terminalToQuery);

    // Construct the URL with the parameters
    const url = `/admin/get_subject_data?className=${encodeURIComponent(className)}&subjectName=${encodeURIComponent(subjectName)}&forTerminal=${encodeURIComponent(terminalToQuery)}`;
    console.log("Fetch URL:", url);

    // Fetch subject data from the server
    const res = await fetch(url);

    if (!res.ok) {
      if (res.status === 404) {
          // Attempt to be more specific with error message
          const errData = await res.json().catch(e => ({}));
          const msg = errData.message || `No data found for ${subjectName} in Class ${className} for Terminal ${terminalToQuery || "Any"}`;
          alert(msg);
          return;
      }
      console.error("Fetch error:", res.status, res.statusText);
      throw new Error(`HTTP error! status: ${res.status}`);
    }

    const data = await res.json();
    console.log("Received data:", data);

    if (!data) {
      alert(`No data found for ${subjectName} in Class ${className}`);
      return;
    }

    // Since we handle 404 separately, getting here means we have data.
    // The previous check (!data || !data.max) might be too strict if data exists but max is 0 or string "0"?
    // But let's keep it robust. If data.max is missing, form generation will fail anyway.

    const confirmMsg = `Found format for ${data.subject} \nClass: ${data.forClass} \nTerminal: ${data.forTerminal} \n\nOverwrite current form?`;

    if (confirm(confirmMsg)) {
         // Update the max questions field
        let maxInput = document.querySelector('#max');
        maxInput.value = parseInt(data.max);

        // Generate the dynamic form with the new max value
        generateDynamicForm(parseInt(data.max));
        
        // Wait for form generation, then populate with the received data
        setTimeout(() => {
        // Populate each question's data
        for (let i = 1; i <= data.max; i++) {
            const subCountKey = `q${i}_subcount`;
            const marksPerSubKey = `q${i}_marks_per_sub`;
            const chapterKey = `q${i}_chapter`;

            // Set Main Chapter if available
            if (data[chapterKey]) {
            const chapSelect = document.getElementById(chapterKey);
            if (chapSelect) {
                chapSelect.value = data[chapterKey];
            }
            }
            
            if (data[subCountKey] && data[marksPerSubKey]) {
            // Set sub-question count
            const subQInput = document.getElementById(`subQuestion${i}`);
            if (subQInput) {
                subQInput.value = data[subCountKey];
            }
            
            // Set marks per sub-question
            const markInput = document.getElementById(`markPerSubQ${i}`);
            if (markInput) {
                markInput.value = data[marksPerSubKey];
            }
            
            // Generate sub-questions for this question
            generateSubQuestions(i, data[subCountKey], data[marksPerSubKey]);
            
            // Populate individual sub-question marks and sub-parts
            setTimeout(() => {
                populateSubQuestionData(i, data, data[subCountKey]);
            }, 200);
            }
        }
        }, 100);

        console.log("Autofill complete");
    }

  } catch (err) {
    console.error("Error occurred during autofill:", err);
    alert(`Error getting data: ${err.message}`);
  }
}

function copyFromTerminal() {
    const selectedTerminal = document.getElementById('copyFromTerminalSelect').value;
    const currentClass = document.getElementById('studentclass').value;
    
    if (!currentClass) {
        alert("Please select a Class first.");
        return;
    }
    if (!selectedTerminal) {
        alert("Please select a Terminal to copy from.");
        return;
    }
    
    // Copy for: Current Class, from Selected Terminal
    autofillFromClass(currentClass, selectedTerminal);
}

// Function to check if subject already exists
async function checkSubjectExistence() {
  // Only check if we are NOT in editing mode
  if (editing === 'true') return;

  const subjectName = document.getElementById('subject').value;
  const className = document.querySelector('select[name="forClass"]').value;
  const terminalVal = document.querySelector('select[name="forTerminal"]').value;

  console.log("Checking existence for:", { subjectName, className, terminalVal });

  if (subjectName && className && terminalVal) {
     try {
       const url = `/admin/get_subject_data?className=${encodeURIComponent(className)}&subjectName=${encodeURIComponent(subjectName)}&forTerminal=${encodeURIComponent(terminalVal)}`;
       const res = await fetch(url);
       
       if (res.ok) {
          // If we get a 200 OK, it means the subject exists
          const data = await res.json();
          // Double check we got actual data
          if (data && data._id) {
             alert(`Subject '${subjectName}' for Class '${className}' in '${terminalVal}' already exists!\n\nYou cannot create a duplicate. Redirecting to Subject List.`);
             window.location.href = '/admin/subject';
          }
       }
     } catch (err) {
       console.error("Error checking subject existence:", err);
     }
  }
}

// Attach listeners to trigger existence check
document.addEventListener("DOMContentLoaded", () => {
    const subjectSelect = document.getElementById('subject');
    const classSelect = document.querySelector('select[name="forClass"]');
    const terminalSelect = document.querySelector('select[name="forTerminal"]');

    if (subjectSelect) subjectSelect.addEventListener('change', checkSubjectExistence);
    if (classSelect) classSelect.addEventListener('change', checkSubjectExistence);
    if (terminalSelect) terminalSelect.addEventListener('change', checkSubjectExistence);
});

// Helper function to populate individual sub-question data
function populateSubQuestionData(questionNum, data, subCount) {
  for (let j = 1; j <= subCount; j++) {
    const letter = String.fromCharCode(96 + j); // a, b, c, etc.
    const subQuestionKey = `q${questionNum}${letter}`;
    
    // Set Chapter for sub-question if available
    const subQChapterKey = `q${questionNum}${letter}_chapter`;
    if (data[subQChapterKey]) {
        const subChapSelect = document.getElementById(subQChapterKey);
        if (subChapSelect) {
             subChapSelect.value = data[subQChapterKey];
        }
    }

    // Set the main marks for the sub-question
    const marksInput = document.querySelector(`input[name="${subQuestionKey}"]`);
    if (marksInput && data[subQuestionKey]) {
      marksInput.value = data[subQuestionKey];
    }
    
    // Check if this sub-question has sub-parts
    const hasSubPartsKey = `${subQuestionKey}_has_subparts`;
    const subPartsCountKey = `${subQuestionKey}_subparts_count`;
    const subPartsMarksKey = `${subQuestionKey}_marks_per_subpart`;
    
    if (data[hasSubPartsKey]) {
      // Check the "has sub-parts" checkbox
      const checkbox = document.getElementById(`hasSubParts_${questionNum}_${letter}`);
      if (checkbox) {
        checkbox.checked = true;
        checkbox.dispatchEvent(new Event('change'));
        
        // Set sub-parts count and marks
        setTimeout(() => {
          const subPartsCountInput = document.querySelector(`input[name="${subPartsCountKey}"]`);
          const subPartsMarksInput = document.querySelector(`input[name="${subPartsMarksKey}"]`);
          
          if (subPartsCountInput && data[subPartsCountKey]) {
            subPartsCountInput.value = data[subPartsCountKey];
          }
          
          if (subPartsMarksInput && data[subPartsMarksKey]) {
            subPartsMarksInput.value = data[subPartsMarksKey];
            
            // Generate sub-parts
            if (subPartsCountInput && subPartsCountInput.value) {
              subPartsCountInput.dispatchEvent(new Event('change'));
              
              // Populate individual sub-part marks
              setTimeout(() => {
                populateSubPartMarks(questionNum, letter, parseInt(subPartsCountInput.value), data);
              }, 200);
            }
          }
        }, 150);
      }
    }
  }
}

// Helper function to populate sub-part marks
function populateSubPartMarks(questionNum, letter, subPartsCount, data) {
  const toRoman = (num) => {
    const romanNumerals = ['i', 'ii', 'iii', 'iv', 'v', 'vi', 'vii', 'viii', 'ix', 'x', 'xi', 'xii', 'xiii', 'xiv', 'xv', 'xvi', 'xvii', 'xviii', 'xix', 'xx'];
    return romanNumerals[num - 1] || num;
  };
  
  for (let k = 1; k <= subPartsCount; k++) {
    const romanNumeral = toRoman(k);
    const subPartKey = `q${questionNum}${letter}_${romanNumeral}`;
    
    const subPartInput = document.querySelector(`input[name="q${questionNum}${letter}.${romanNumeral}"]`);
    if (subPartInput && data[subPartKey]) {
      subPartInput.value = data[subPartKey];
    }
  }
}

// Add event listener to the "Same as" dropdown
// This will trigger the autofill function when a class is selected
document.getElementById('sameas').addEventListener('change', function() {
  const selectedClass = this.value; // Get the string value directly
  console.log("Selected class from dropdown:", selectedClass);

  if (selectedClass && selectedClass !== '') {
    // Call the autofill function with the selected class value
    autofillFromClass(selectedClass);
  } else {
    console.warn("No class selected");
  }
});

// Add file selection feedback for editing mode
if (editing === true) {
  const fileInput = document.getElementById('questionPaper');
  const currentFileAlert = document.querySelector('.alert-info');

  fileInput.addEventListener('change', function() {
    if (this.files.length > 0) {
      const fileName = this.files[0].name;

      // Update the alert to show new file selection
      if (currentFileAlert) {
        currentFileAlert.innerHTML = `
          <i class="fas fa-upload me-2"></i>
          <strong>New file selected:</strong> ${fileName}
          <br>
          <small class="text-muted">This will replace the current question paper when you save.</small>
        `;
        currentFileAlert.className = 'alert alert-warning py-2';
      }
    } else {
      // Reset to original state if no file selected
      if (currentFileAlert && typeof subjectedit !== 'undefined' && subjectedit.questionPaperOfClass) {
        currentFileAlert.innerHTML = `
          <i class="fas fa-info-circle me-2"></i>
          <strong>Current file:</strong> ${subjectedit.questionPaperOfClass}
          ${subjectedit.questionPaperOfClass !== 'default.pdf' ? `<a href="/file-viewer/${subjectedit.questionPaperOfClass}" target="_blank" class="btn btn-sm btn-outline-primary ms-2"><i class="fas fa-eye"></i> View File</a>` : ''}
          <br>
          <small class="text-muted">Select a new file above to replace the current question paper, or leave empty to keep the existing file.</small>
        `;
        currentFileAlert.className = 'alert alert-info py-2';
      }
    }
  });
}

  </script>














