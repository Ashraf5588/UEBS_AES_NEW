<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Transfer</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #1954a6;
            --primary-dark: #0e2c5c;
            --accent: #f0841f;
            --bg: #f5f7fb;
            --card: #ffffff;
            --text: #1f2937;
            --muted: #64748b;
            --success: #16a34a;
            --danger: #dc2626;
            --border: rgba(148, 163, 184, 0.2);
            --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(25, 84, 166, 0.12), transparent 28%),
                radial-gradient(circle at top right, rgba(240, 132, 31, 0.12), transparent 24%),
                linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%);
            color: var(--text);
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 1.5rem;
        }

        .header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            color: white;
            border-radius: 24px;
            padding: 1.75rem;
            box-shadow: var(--shadow);
            margin-bottom: 1.25rem;
        }

        .header h1 {
            margin: 0 0 0.35rem;
            font-size: 2rem;
        }

        .header p {
            margin: 0;
            opacity: 0.92;
        }

        .grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 1.25rem;
        }

        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 22px;
            box-shadow: var(--shadow);
            padding: 1.25rem;
        }

        .card h2 {
            margin: 0 0 1rem;
            font-size: 1.15rem;
            color: var(--primary-dark);
        }

        .hint {
            color: var(--muted);
            font-size: 0.95rem;
            margin-bottom: 1rem;
        }

        .chip-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.65rem;
            margin-bottom: 1rem;
        }

        .chip {
            border: 1px solid var(--border);
            background: #fff;
            color: var(--text);
            padding: 0.7rem 0.95rem;
            border-radius: 999px;
            cursor: pointer;
            font-weight: 700;
            transition: all 0.2s ease;
        }

        .chip.active {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border-color: transparent;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
        }

        .field label {
            display: block;
            margin-bottom: 0.45rem;
            font-weight: 700;
        }

        .field select,
        .field input {
            width: 100%;
            padding: 0.8rem 0.9rem;
            border-radius: 12px;
            border: 1px solid var(--border);
            font-size: 1rem;
            background: #fff;
        }

        .student-panel {
            margin-top: 1rem;
            border-top: 1px dashed var(--border);
            padding-top: 1rem;
        }

        .student-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.75rem;
            flex-wrap: wrap;
        }

        .student-count {
            color: var(--muted);
            font-weight: 600;
        }

        .student-list {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.75rem;
            max-height: 460px;
            overflow: auto;
            padding-right: 0.25rem;
        }

        .student-item {
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 0.85rem;
            background: #fafcff;
            position: relative;
        }

        .student-item.selected {
            border-color: rgba(25, 84, 166, 0.4);
            background: #f3f8ff;
        }

        .student-item label {
            display: flex;
            gap: 0.75rem;
            align-items: flex-start;
            cursor: pointer;
        }

        .student-item input {
            margin-top: 0.2rem;
        }

        .student-name {
            font-weight: 700;
            display: block;
        }

        .student-meta {
            display: block;
            color: var(--muted);
            font-size: 0.9rem;
            margin-top: 0.15rem;
        }

        .selection-badge {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            min-width: 1.65rem;
            height: 1.65rem;
            padding: 0 0.45rem;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
            font-weight: 800;
            font-size: 0.82rem;
            opacity: 0;
            transform: scale(0.95);
            transition: opacity 0.15s ease, transform 0.15s ease;
        }

        .student-item.selected .selection-badge {
            opacity: 1;
            transform: scale(1);
        }

        .actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-top: 1.1rem;
        }

        .btn {
            border: none;
            border-radius: 14px;
            padding: 0.9rem 1.1rem;
            font-weight: 800;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
        }

        .btn-secondary {
            background: #e2e8f0;
            color: var(--text);
        }

        .summary {
            display: grid;
            gap: 0.75rem;
        }

        .summary-box {
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 1rem;
            background: #fff;
        }

        .summary-box strong {
            display: block;
            margin-bottom: 0.35rem;
        }

        .preview-table {
            width: 100%;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: #fff;
        }

        .preview-table th,
        .preview-table td {
            padding: 0.7rem 0.8rem;
            border-bottom: 1px solid var(--border);
            text-align: left;
            font-size: 0.92rem;
        }

        .preview-table th {
            background: #f8fbff;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--muted);
        }

        .preview-table tr:last-child td {
            border-bottom: none;
        }

        .preview-note {
            margin-top: 0.75rem;
            color: var(--muted);
            font-size: 0.92rem;
        }

        .notification {
            position: fixed;
            top: 18px;
            right: 18px;
            z-index: 1000;
            color: #fff;
            font-weight: 700;
            padding: 0.9rem 1.1rem;
            border-radius: 14px;
            box-shadow: var(--shadow);
            transform: translateX(120%);
            transition: transform 0.25s ease;
            max-width: 360px;
        }

        .notification.show { transform: translateX(0); }
        .notification.success { background: linear-gradient(135deg, #16a34a, #15803d); }
        .notification.error { background: linear-gradient(135deg, #dc2626, #b91c1c); }

        .empty-state {
            border: 1px dashed var(--border);
            border-radius: 18px;
            padding: 1.25rem;
            text-align: center;
            color: var(--muted);
            background: #fbfdff;
        }

        @media (max-width: 960px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .container { padding: 1rem; }
            .header { padding: 1.25rem; }
            .header h1 { font-size: 1.5rem; }
            .form-grid, .student-list { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidenav', {
        subjects: subjects || [],
        studentClassdata: studentClassdata || [],
        terminals: terminals || []
    }) %>

    <div class="container">
        <div class="header">
            <h1><i class="fas fa-user-pen"></i> Student Transfer</h1>
            <p>Select a previous class-section, check the students you want to promote, then move them to the new class-section for the next academic session.</p>
        </div>

        <div class="grid">
            <div class="card">
                <h2><i class="fas fa-users"></i> Select Students</h2>
                <div class="hint">Start by choosing the previous class. The section list and student checkboxes will appear automatically.</div>

                <div class="chip-row" id="classButtons">
                    <% (availableClasses || []).forEach((className) => { %>
                        <button type="button" class="chip" data-class="<%= className %>"><%= className %></button>
                    <% }) %>
                </div>

                <form id="transferForm" action="/student-transfer" method="POST">
                    <input type="hidden" name="sourceClass" id="sourceClass" />
                    <input type="hidden" name="selectionOrder" id="selectionOrder" />
                    <div class="form-grid">
                        <div class="field">
                            <label for="sourceSection">Previous Section</label>
                            <select id="sourceSection" name="sourceSection" disabled>
                                <option value="">Select class first</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="targetClass">New Class</label>
                            <select id="targetClass" name="targetClass" required>
                                <option value="">Select new class</option>
                                <% (availableClasses || []).forEach((className) => { %>
                                    <option value="<%= className %>"><%= className %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="field">
                            <label for="targetSection">New Section</label>
                            <select id="targetSection" name="targetSection" required>
                                <option value="">Select new class first</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="studentSearch">Search</label>
                            <input type="text" id="studentSearch" placeholder="Search by name or reg number">
                        </div>
                    </div>

                    <div class="student-panel">
                        <div class="student-toolbar">
                            <label style="display:flex;align-items:center;gap:0.5rem;font-weight:700;cursor:pointer;">
                                <input type="checkbox" id="selectAllStudents" disabled>
                                Select all shown students
                            </label>
                            <div class="student-count" id="studentCount">No class selected</div>
                        </div>
                        <div class="student-list" id="studentList">
                            <div class="empty-state">Choose a class and section to load students.</div>
                        </div>
                    </div>

                    <div class="actions">
                        <button type="submit" class="btn btn-primary" id="transferBtn" disabled>
                            <i class="fas fa-right-left"></i>
                            Update Selected Students
                        </button>
                        <a href="/studentrecord" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i>
                            Back to Student Records
                        </a>
                    </div>
                </form>
            </div>

            <div class="card">
                <h2><i class="fas fa-clipboard-list"></i> Transfer Summary</h2>
                <div class="summary">
                    <div class="summary-box">
                        <strong>How it works</strong>
                        Pick the old class-section from the buttons, select the section, then check the students who should move to the next year.
                    </div>
                    <div class="summary-box">
                        <strong>Update target</strong>
                        Choose the new class and section for the next academic session before submitting.
                    </div>
                    <div class="summary-box">
                        <strong>Result</strong>
                        The selected students are updated in the <em>studentrecord</em> collection with the new class and section values.
                    </div>
                    <div class="summary-box">
                        <strong>Roll preview</strong>
                        <div id="rollPreviewEmpty">Choose students to preview the new numbering. Rolls start from 1 in the checked order.</div>
                        <div id="rollPreviewWrap" style="display:none; margin-top: 0.75rem;">
                            <table class="preview-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Student</th>
                                        <th>Old Roll</th>
                                        <th>New Roll</th>
                                    </tr>
                                </thead>
                                <tbody id="rollPreviewBody"></tbody>
                            </table>
                            <div class="preview-note">The system will apply these rolls in the order you checked them, starting from 1.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="notification" id="notification"></div>

    <script>
        const studentRecords = <%- JSON.stringify(studentRecords || []) %>;
        const availableClassSections = <%- JSON.stringify(availableClassSections || []) %>;
        const classButtons = document.querySelectorAll('.chip[data-class]');
        const sourceClassInput = document.getElementById('sourceClass');
        const sourceSectionSelect = document.getElementById('sourceSection');
        const targetClassSelect = document.getElementById('targetClass');
        const targetSectionSelect = document.getElementById('targetSection');
        const studentList = document.getElementById('studentList');
        const studentCount = document.getElementById('studentCount');
        const transferBtn = document.getElementById('transferBtn');
        const transferForm = document.getElementById('transferForm');
        const selectAllStudents = document.getElementById('selectAllStudents');
        const studentSearch = document.getElementById('studentSearch');
        const selectionOrderInput = document.getElementById('selectionOrder');
        const rollPreviewEmpty = document.getElementById('rollPreviewEmpty');
        const rollPreviewWrap = document.getElementById('rollPreviewWrap');
        const rollPreviewBody = document.getElementById('rollPreviewBody');

        const state = {
            sourceClass: '',
            sourceSection: '',
            targetClass: '',
            targetSection: '',
            selectionOrder: []
        };

        function normalize(value) {
            return String(value || '').trim().toLowerCase();
        }

        function showNotification(message, type) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification ${type} show`;
            setTimeout(() => notification.classList.remove('show'), 3500);
        }

        function getSectionsForClass(className) {
            const sections = availableClassSections
                .filter((item) => normalize(item.studentClass) === normalize(className))
                .map((item) => String(item.section || '').trim().toUpperCase())
                .filter(Boolean);

            return [...new Set(sections)];
        }

        function renderSectionOptions(selectElement, className, placeholder) {
            const sections = getSectionsForClass(className);
            selectElement.innerHTML = '';
            const firstOption = document.createElement('option');
            firstOption.value = '';
            firstOption.textContent = placeholder;
            selectElement.appendChild(firstOption);

            sections.forEach((section) => {
                const option = document.createElement('option');
                option.value = section;
                option.textContent = section;
                selectElement.appendChild(option);
            });

            selectElement.disabled = sections.length === 0;
        }

        function getFilteredStudents() {
            return studentRecords.filter((student) => {
                return normalize(student.studentClass) === normalize(state.sourceClass)
                    && normalize(student.section) === normalize(state.sourceSection);
            });
        }

        function getVisibleCheckboxes() {
            return Array.from(studentList.querySelectorAll('input[type="checkbox"][name="studentIds"]'));
        }

        function syncSelectionOrderInput() {
            selectionOrderInput.value = JSON.stringify(state.selectionOrder);
        }

        function renumberSelectedCards() {
            const orderMap = new Map(state.selectionOrder.map((id, index) => [String(id), index + 1]));

            studentList.querySelectorAll('.student-item').forEach((item) => {
                const checkbox = item.querySelector('input[type="checkbox"][name="studentIds"]');
                const badge = item.querySelector('.selection-badge');
                const orderNumber = checkbox && checkbox.checked ? orderMap.get(String(checkbox.value)) : null;

                item.classList.toggle('selected', Boolean(orderNumber));
                badge.textContent = orderNumber ? String(orderNumber) : '';
            });
        }

        function updateSelectionState(studentId, checked) {
            const normalizedId = String(studentId);

            if (checked) {
                if (!state.selectionOrder.includes(normalizedId)) {
                    state.selectionOrder.push(normalizedId);
                }
            } else {
                state.selectionOrder = state.selectionOrder.filter((id) => id !== normalizedId);
            }

            syncSelectionOrderInput();
            renumberSelectedCards();
            renderRollPreview();
        }

        function getVisibleStudents() {
            const filteredStudents = getFilteredStudents();
            const query = normalize(studentSearch.value);

            return filteredStudents.filter((student) => {
                if (!query) return true;
                return normalize(student.name).includes(query) || normalize(student.reg).includes(query);
            });
        }

        function getSelectedVisibleStudents() {
            const selectedIds = new Set(getVisibleCheckboxes().filter((checkbox) => checkbox.checked).map((checkbox) => checkbox.value));
            const allById = new Map(studentRecords.map((student) => [String(student._id), student]));

            return state.selectionOrder
                .map((studentId) => allById.get(String(studentId)))
                .filter(Boolean)
                .filter((student) => selectedIds.has(String(student._id)));
        }

        function renderRollPreview() {
            const selectedStudents = getSelectedVisibleStudents();
            if (!state.sourceClass || !state.sourceSection || selectedStudents.length === 0) {
                rollPreviewEmpty.style.display = 'block';
                rollPreviewWrap.style.display = 'none';
                if (!state.sourceClass || !state.sourceSection) {
                    rollPreviewEmpty.textContent = 'Choose a source class and section first.';
                } else if (selectedStudents.length === 0) {
                    rollPreviewEmpty.textContent = 'Select students to preview the new roll sequence.';
                }
                return;
            }

            const previewRows = selectedStudents.map((student, index) => {
                const rollValue = index + 1;
                return `
                    <tr>
                        <td>${index + 1}</td>
                        <td>${student.name || ''}${student.reg ? ` <span style="color: var(--muted);">(${student.reg})</span>` : ''}</td>
                        <td>${student.roll ?? ''}</td>
                        <td><strong>${rollValue}</strong></td>
                    </tr>
                `;
            }).join('');

            rollPreviewBody.innerHTML = previewRows;
            rollPreviewEmpty.style.display = 'none';
            rollPreviewWrap.style.display = 'block';
        }

        function renderStudents() {
            const visibleStudents = getVisibleStudents();

            studentCount.textContent = state.sourceClass && state.sourceSection
                ? `${visibleStudents.length} student(s) shown from ${state.sourceClass} ${state.sourceSection}`
                : 'No class selected';

            selectAllStudents.checked = false;
            selectAllStudents.disabled = visibleStudents.length === 0;

            if (!state.sourceClass || !state.sourceSection) {
                studentList.innerHTML = '<div class="empty-state">Choose a class and section to load students.</div>';
                transferBtn.disabled = true;
                return;
            }

            if (visibleStudents.length === 0) {
                studentList.innerHTML = '<div class="empty-state">No students found for the selected class-section.</div>';
                transferBtn.disabled = true;
                return;
            }

            studentList.innerHTML = visibleStudents.map((student) => {
                const label = [student.name, student.reg ? `Reg: ${student.reg}` : '', student.roll ? `Roll: ${student.roll}` : '']
                    .filter(Boolean)
                    .join(' | ');

                return `
                    <div class="student-item" data-student-id="${String(student._id)}">
                        <span class="selection-badge"></span>
                        <label>
                            <input type="checkbox" name="studentIds" value="${String(student._id)}" ${state.selectionOrder.includes(String(student._id)) ? 'checked' : ''}>
                            <span>
                                <span class="student-name">${label}</span>
                                <span class="student-meta">${String(student.studentClass || '')} ${String(student.section || '')}</span>
                            </span>
                        </label>
                    </div>
                `;
            }).join('');

            renumberSelectedCards();
            transferBtn.disabled = false;
            renderRollPreview();
        }

        classButtons.forEach((button) => {
            button.addEventListener('click', () => {
                classButtons.forEach((item) => item.classList.remove('active'));
                button.classList.add('active');

                state.sourceClass = button.dataset.class || '';
                sourceClassInput.value = state.sourceClass;
                state.sourceSection = '';
                sourceSectionSelect.disabled = false;

                renderSectionOptions(sourceSectionSelect, state.sourceClass, 'Select previous section');
                renderStudents();
            });
        });

        sourceSectionSelect.addEventListener('change', () => {
            state.sourceSection = sourceSectionSelect.value;
            renderStudents();
        });

        targetClassSelect.addEventListener('change', () => {
            state.targetClass = targetClassSelect.value;
            renderSectionOptions(targetSectionSelect, state.targetClass, 'Select new section');
        });

        targetSectionSelect.addEventListener('change', () => {
            state.targetSection = targetSectionSelect.value;
        });

        selectAllStudents.addEventListener('change', () => {
            const visibleCheckboxes = getVisibleCheckboxes();
            visibleCheckboxes.forEach((checkbox) => {
                checkbox.checked = selectAllStudents.checked;
            });
            if (selectAllStudents.checked) {
                visibleCheckboxes.forEach((checkbox) => {
                    if (!state.selectionOrder.includes(checkbox.value)) {
                        state.selectionOrder.push(checkbox.value);
                    }
                });
            } else {
                state.selectionOrder = state.selectionOrder.filter((studentId) => !visibleCheckboxes.some((checkbox) => checkbox.value === studentId));
            }
            syncSelectionOrderInput();
            renumberSelectedCards();
            renderRollPreview();
        });

        studentSearch.addEventListener('input', renderStudents);

        studentList.addEventListener('change', (event) => {
            if (event.target && event.target.name === 'studentIds') {
                updateSelectionState(event.target.value, event.target.checked);
                const visibleCheckboxes = getVisibleCheckboxes();
                selectAllStudents.checked = visibleCheckboxes.length > 0 && visibleCheckboxes.every((checkbox) => checkbox.checked);
            }
        });

        transferForm.addEventListener('submit', (event) => {
            const checkedStudents = getVisibleCheckboxes().filter((checkbox) => checkbox.checked);
            syncSelectionOrderInput();

            if (!state.sourceClass || !state.sourceSection) {
                event.preventDefault();
                showNotification('Select the previous class and section first.', 'error');
                return;
            }

            if (!state.targetClass || !state.targetSection) {
                event.preventDefault();
                showNotification('Select the new class and section first.', 'error');
                return;
            }

            if (checkedStudents.length === 0) {
                event.preventDefault();
                showNotification('Select at least one student to update.', 'error');
                return;
            }
        });

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('success') === 'true') {
            const count = urlParams.get('count') || '0';
            showNotification(`Updated ${count} student(s) successfully.`, 'success');
        }
        if (urlParams.get('error')) {
            showNotification('Unable to update the selected students.', 'error');
        }
    </script>
</body>
</html>
