            </select>
          </td>
          <% dayList.forEach((day) => { %>
            <% const isHoliday = holidayDays.includes(day); %>
            <td class="<%= isHoliday ? 'holiday' : '' %>">
              <div class="day-cell">
                <input
                  type="checkbox"
