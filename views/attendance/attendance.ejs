<!-- script for autosave the data -->
 <script>
  const saveTimers = new Map();
    const informSaveTimers = new Map();

  async function autoSaveCheckbox(el) {
    if (saveTimers.has(el)) {
      clearTimeout(saveTimers.get(el));
    }

    const timer = setTimeout(async() => {
      const reg = el.dataset.reg;
      const day = el.dataset.day;
      const month = el.dataset.month;
      const academicYear = el.dataset.academicyear;
      const param = new URLSearchParams(window.location.search);
      const studentClass = param.get('studentClass');
      const section = param.get('section');
      const name = document.querySelector(`input[name="name[${reg}]"]`).value;
      const roll = document.querySelector(`input[name="roll[${reg}]"]`).value;
      const gender = document.querySelector(`input[name="gender[${reg}]"]`).value;
      const status = el.checked ? 'absent' : 'present';
      const informElements = getInformElements(reg, day);

      applyInformUiState(informElements, el.checked);
      const isInformed = Boolean(informElements.toggle && informElements.toggle.checked);
      const reason = String(informElements.reason && informElements.reason.value || '').trim();

      try {
        const response = await fetch(`/saveonlineattendance?studentClass=${studentClass}&section=${section}&academicYear=${academicYear}`,{
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            reg,
            studentClass,
            section,
            academicYear,
            month,
            day,
            status,
            name,
            roll,
            gender,
            reason,
            informed: isInformed,
          })
        });

        if (!response.ok) {
          console.error('Failed to save attendance');
        } else {
          setSavedHighlight(el, el.checked);
        }
      } catch (err) {
        console.error(err);
      }

      saveTimers.delete(el);
    }, 700);

    saveTimers.set(el, timer);
  }

  document.querySelectorAll('.attendance-check').forEach((checkbox) => {
    checkbox.addEventListener('change', () => autoSaveCheckbox(checkbox));
  });

  async function autoSaveInform(toggleEl) {
    if (informSaveTimers.has(toggleEl)) {
      clearTimeout(informSaveTimers.get(toggleEl));
    }

    const timer = setTimeout(async() => {
      const reg = toggleEl.dataset.reg;
      const day = toggleEl.dataset.day;
      const month = toggleEl.dataset.month;
      const academicYear = toggleEl.dataset.academicyear;
      const param = new URLSearchParams(window.location.search);
      const studentClass = param.get('studentClass');
      const section = param.get('section');
      const name = document.querySelector(`input[name="name[${reg}]"]`).value;
      const roll = document.querySelector(`input[name="roll[${reg}]"]`).value;
      const gender = document.querySelector(`input[name="gender[${reg}]"]`).value;
      const attendanceCheckbox = document.querySelector(`.attendance-check[data-reg="${reg}"][data-day="${day}"]`);
      const status = attendanceCheckbox && attendanceCheckbox.checked ? 'absent' : 'present';
      const reasonEl = document.querySelector(`.inform-reason[data-reg="${reg}"][data-day="${day}"]`);
      const reason = String(reasonEl && reasonEl.value || '').trim();

      applyInformUiState(getInformElements(reg, day), status === 'absent');

      try {
        const response = await fetch(`/saveonlineattendance?studentClass=${studentClass}&section=${section}&academicYear=${academicYear}` ,{
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            reg,
            studentClass,
            section,
            academicYear,
            month,
            day,
            status,
            name,
            roll,
            gender,
            reason,
            informed: toggleEl.checked
          })
        });

        if (!response.ok) {
          console.error('Failed to save inform status');
        }
      } catch (err) {
        console.error(err);
      }

      informSaveTimers.delete(toggleEl);
    }, 600);

    informSaveTimers.set(toggleEl, timer);
  }

  document.querySelectorAll('.inform-check').forEach((toggleEl) => {
    toggleEl.addEventListener('change', () => {
      const reg = toggleEl.dataset.reg;
      const day = toggleEl.dataset.day;
      const elements = getInformElements(reg, day);
      applyInformUiState(elements, Boolean(document.querySelector(`.attendance-check[data-reg="${reg}"][data-day="${day}"]`)?.checked));
      autoSaveInform(toggleEl);
    });
  });

  document.querySelectorAll('.inform-reason').forEach((reasonEl) => {
    reasonEl.addEventListener('input', () => {
      const reg = reasonEl.dataset.reg;
      const day = reasonEl.dataset.day;
      const toggleEl = document.querySelector(`.inform-check[data-reg="${reg}"][data-day="${day}"]`);
      if (toggleEl) {
        autoSaveInform(toggleEl);
      }
    });
  });

  document.querySelectorAll('.attendance-check').forEach((checkbox) => {
    const reg = checkbox.dataset.reg;
    const day = checkbox.dataset.day;
    applyInformUiState(getInformElements(reg, day), checkbox.checked);
  });
 </script>
