<script>
  const rollToggleButton = document.getElementById('toggleRollEdit');
  const rollInputs = Array.from(document.querySelectorAll('.roll-input'));
  const rollSaveTimers = new Map();
  let rollEditEnabled = false;

  function setRollEditMode(enabled) {
    rollEditEnabled = Boolean(enabled);
    document.body.classList.toggle('roll-editing', rollEditEnabled);
    rollInputs.forEach((input) => {
      input.readOnly = !rollEditEnabled;
    });
    if (!rollEditEnabled) {
      rollInputs.forEach((input) => {
        if (!String(input.value || '').trim()) {
          input.value = input.dataset.original || '';
        }
      });
    }
    if (rollToggleButton) {
      rollToggleButton.classList.toggle('active', rollEditEnabled);
      rollToggleButton.textContent = rollEditEnabled ? 'Done Editing' : 'Edit Roll Numbers';
    }
  }

  async function saveRollNumber(input) {
    const reg = input.dataset.reg;
    const original = input.dataset.original || '';
    const nextRoll = String(input.value || '').trim();

    if (!rollEditEnabled || !reg) {
      return;
    }

    if (!nextRoll || nextRoll === original) {
      return;
    }

    if (rollSaveTimers.has(input)) {
      clearTimeout(rollSaveTimers.get(input));
    }

    const timer = setTimeout(async () => {
      const param = new URLSearchParams(window.location.search);
      const studentClass = param.get('studentClass');
      const section = param.get('section');
      const academicYear = param.get('academicYear');

      try {
        const response = await fetch('/updateStudentRoll', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            reg,
            roll: nextRoll,
            studentClass,
            section,
            academicYear
          })
        });

        if (!response.ok) {
          input.value = original;
          return;
        }

        input.dataset.original = nextRoll;
      } catch (error) {
        input.value = original;
        console.error('Failed to update roll number:', error);
      } finally {
        rollSaveTimers.delete(input);
      }
    }, 600);

    rollSaveTimers.set(input, timer);
  }

  if (rollToggleButton) {
    rollToggleButton.addEventListener('click', () => setRollEditMode(!rollEditEnabled));
  }

  rollInputs.forEach((input) => {
    input.addEventListener('input', () => saveRollNumber(input));
    input.addEventListener('blur', () => {
      if (!String(input.value || '').trim()) {
        input.value = input.dataset.original || '';
      }
    });
  });

  setRollEditMode(false);
</script>

