     <input type="hidden" name="section" id="section" value="<%=section %>">

  </form>
</div>

<script>
function normalizeMonth(value) {
  return String(value || '').trim().toLowerCase();
}

function isAbsentStatus(status) {
  const normalized = String(status || '').trim().toLowerCase();
  return normalized === 'absent' || normalized === 'a' || normalized === 'false';
}

function setSavedHighlight(checkbox, isSavedAbsent) {
  if (!checkbox) {
    return;
  }
  checkbox.classList.toggle('saved-absent', Boolean(isSavedAbsent));
}

function getInformElements(reg, day) {
  const toggle = document.querySelector(`.inform-check[data-reg="${reg}"][data-day="${day}"]`);
  const reason = document.querySelector(`.inform-reason[data-reg="${reg}"][data-day="${day}"]`);
  const label = toggle ? toggle.closest('.inform-toggle')?.querySelector('.inform-label') : null;
  return { toggle, reason, label };
}

function applyInformUiState({ toggle, reason, label }, isAbsent) {
  if (!toggle || !reason) {
    return;
  }

  const isHoliday = String(toggle.dataset.holiday || '') === 'true';
  const shouldDisable = !isAbsent || isHoliday;
  toggle.disabled = shouldDisable;
  reason.disabled = shouldDisable;

  if (!isAbsent) {
    toggle.checked = false;
    reason.value = '';
  }

  const isInformed = toggle.checked && !toggle.disabled;
  reason.classList.toggle('show', isInformed);
  if (label) {
    label.textContent = isInformed ? 'Informed' : 'Not informed';
  }
}

const MONTH_ALIAS_MAP = {
  asar: ['asar', 'ashar', 'ashadh'],
  ashar: ['asar', 'ashar', 'ashadh'],
  ashadh: ['asar', 'ashar', 'ashadh'],
  ashwin: ['ashwin', 'ashoj'],
  ashoj: ['ashwin', 'ashoj']
};

function isSameMonthValue(selectedMonth, entryMonth) {
  const selected = normalizeMonth(selectedMonth);
  const entry = normalizeMonth(entryMonth);
  if (!selected || !entry) {
    return false;
  }
  if (selected === entry) {
    return true;
  }
  const selectedAliases = MONTH_ALIAS_MAP[selected] || [selected];
  return selectedAliases.includes(entry);
}

async function populateData(studentClass,section,academicYear,month)
{
  if (!studentClass || !section || !academicYear || !month) {
    return;
  }

  try {
    const attendanceData = await fetch(`/getOnlineAttendanceData?studentClass=${studentClass}&section=${section}&academicYear=${academicYear}`);
    const attendanceResult = await attendanceData.json();

    if (!Array.isArray(attendanceResult) || attendanceResult.length === 0) {
      console.log("No attendance data found");
      return;
    }

    const selectedMonth = normalizeMonth(month);

    attendanceResult.forEach((item) => {
      const reg = item.reg;
      const entries = Array.isArray(item.attendance) ? item.attendance : [];

      entries.forEach((entry) => {
        const sameYear = String(entry.academicYear) === String(academicYear);
        const sameMonth = isSameMonthValue(selectedMonth, entry.month);

        if (!sameYear || !sameMonth) {
          return;
        }

        const selector = `.attendance-check[data-reg="${reg}"][data-day="${String(entry.day)}"]`;
        const checkbox = document.querySelector(selector);
        if (!checkbox) {
          return;
        }

        const absent = isAbsentStatus(entry.status);
        checkbox.checked = absent;
        setSavedHighlight(checkbox, absent);

        const informElements = getInformElements(reg, String(entry.day));
        const savedReason = String(entry.reason || '').trim();
        if (informElements.toggle) {
          informElements.toggle.checked = Boolean(savedReason);
        }
        if (informElements.reason) {
          informElements.reason.value = savedReason;
        }
        applyInformUiState(informElements, absent);
      });
    });
  } catch (error) {
    console.error('Error loading online attendance data:', error);
  }
}






