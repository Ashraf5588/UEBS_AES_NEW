                data-holiday="<%= isHoliday ? 'true' : 'false' %>"
                <%= isHoliday ? 'disabled' : '' %>
              ></textarea>
            </td>
          <% }) %>
          
        </tr>

      <%})%>
    </table>
    </div>

   

   
    
   
   
    
