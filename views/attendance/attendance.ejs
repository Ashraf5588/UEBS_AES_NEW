                  data-holiday="<%= isHoliday ? 'true' : 'false' %>"
                  <%= isHoliday ? 'disabled' : '' %>
                  id="att-<%= student.reg %>-<%= day %>"
                >
                <label class="day-box" for="att-<%= student.reg %>-<%= day %>"><%= day %></label>
              </div>
            </td>
          <% }) %>
          <% dayList.forEach((day) => { %>
            <% const isHoliday = holidayDays.includes(day); %>
            <td class="inform-cell">
              <div class="inform-toggle">
                <label class="toggle">
