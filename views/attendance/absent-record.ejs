<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Absent Record</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700;800&family=Manrope:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --ink:#1f2937;
      --muted:#6b7280;
      --accent:#f97316;
      --accent-dark:#ea580c;
      --sky:#1f3b73;
      --sky-light:#345b9a;
      --paper:#ffffff;
      --bg:#eef2f9;
      --border:#d7e0ee;
      --row:#f9fbff;
      --shadow:0 18px 40px rgba(15,23,42,.12)
    }

    *{box-sizing:border-box;margin:0;padding:0}

    body{
      font-family:'Lexend',sans-serif;
      background:
        radial-gradient(circle at top right, rgba(249,115,22,.18), transparent 45%),
        radial-gradient(circle at top left, rgba(31,59,115,.18), transparent 45%),
        linear-gradient(180deg, #eef2f9 0%, #f7f9fd 100%);
      color:var(--ink);
      min-height:100vh;
      padding:24px 18px 40px;
    }

    .page{
      max-width:1040px;
      margin:0 auto;
    }

    .header{
      background:linear-gradient(135deg, var(--sky) 0%, var(--sky-light) 55%, var(--accent) 100%);
      color:#fff;
      padding:22px 24px;
      border-radius:18px;
      box-shadow:var(--shadow);
    }

    .title{
      font-size:26px;
      font-weight:800;
      letter-spacing:.3px;
    }

    .subtitle{
      margin-top:6px;
      color:rgba(255,255,255,.88);
      font-size:14px;
    }

    .filters{
      margin-top:18px;
      background:var(--paper);
      border:1px solid var(--border);
      border-radius:16px;
      padding:16px 18px;
      box-shadow:0 10px 28px rgba(15,23,42,.08);
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
      gap:12px;
      align-items:end;
    }

    .filters label{
      font-size:12px;
      font-weight:700;
      color:var(--muted);
      margin-bottom:6px;
      display:block;
    }

    .filters select{
      width:100%;
      padding:8px 10px;
      border:1px solid var(--border);
      border-radius:10px;
      background:#fff;
      color:var(--ink);
      font-size:13px;
    }

    .filters .btn{
      border:0;
      border-radius:10px;
      padding:10px 12px;
      font-weight:700;
      cursor:pointer;
      font-size:13px;
      letter-spacing:.3px;
    }

    .btn-primary{
      background:linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
      color:#fff;
    }

    .btn-outline{
      background:#fff;
      border:1px solid var(--border);
      color:var(--ink);
    }

    .btn-print{
      background:linear-gradient(135deg, #0f172a 0%, #334155 100%);
      color:#fff;
      border:1px solid #0f172a;
      letter-spacing:.4px;
    }

    .btn-print:hover{
      filter:brightness(1.05);
    }

    .content{
      margin-top:22px;
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:18px;
    }

    .group-card{
      background:var(--paper);
      border-radius:16px;
      border:1px solid var(--border);
      box-shadow:0 12px 26px rgba(15,23,42,.08);
      padding:16px 18px;
    }

    .group-header{
      display:flex;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding-bottom:12px;
      border-bottom:1px dashed var(--border);
    }

    .group-title{
      font-size:16px;
      font-weight:800;
      color:var(--sky);
    }

    .group-count{
      background:rgba(249,115,22,.12);
      color:var(--accent-dark);
      font-weight:700;
      padding:6px 12px;
      border-radius:999px;
      font-size:12px;
      letter-spacing:.3px;
    }

    table{
      width:100%;
      border-collapse:collapse;
      margin-top:12px;
    }

    th,td{
      text-align:left;
      padding:8px 10px;
      font-size:13px;
    }

    thead th{
      color:var(--muted);
      font-weight:700;
      border-bottom:1px solid var(--border);
    }

    tbody tr:nth-child(even){
      background:var(--row);
    }

    .reason{
      display:block;
      margin-top:4px;
      font-size:11px;
      color:var(--muted);
      line-height:1.35;
    }

    .empty{
      padding:28px;
      text-align:center;
      color:var(--muted);
      font-weight:600;
      background:var(--paper);
      border-radius:16px;
      border:1px solid var(--border);
    }

    @media (max-width:720px){
      .title{font-size:22px}
      .group-title{font-size:15px}
      .filters{grid-template-columns:repeat(auto-fit,minmax(140px,1fr))}
      .content{grid-template-columns:1fr}
    }

    @media print{
      body{
        background:#fff;
        padding:0;
      }

      .header,
      .filters,
      .btn-outline,
      .btn-primary{
        display:none !important;
      }

      .page{
        max-width:100%;
        margin:0;
      }

      .group-card{
        box-shadow:none;
        border:1px solid #000;
        page-break-inside:avoid;
      }

      .empty{
        border:1px solid #000;
      }

      @page{
        size:A4;
        margin:12mm;
      }

      .content{
        grid-template-columns:repeat(2, minmax(0, 1fr));
        gap:12px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="header">
      <div class="title">Absent Record</div>
      <div class="subtitle">
        Date (BS): <strong><%= todayBs %></strong>
        | Academic Year: <strong><%= academicYear %></strong>
        | Month: <strong><%= currentMonthName %></strong>
        | Day: <strong><%= todayDay %></strong>
        | Total Absent: <strong><%= totalAbsentCount || 0 %></strong>
      </div>
    </header>

    <form class="filters" method="GET" action="/absent-record">
      <div>
        <label for="academicYear">Academic Year</label>
        <select name="academicYear" id="academicYear">
          <% (academicYearOptions || []).forEach((year) => { %>
            <option value="<%= year %>" <%= String(year) === String(academicYear) ? 'selected' : '' %>><%= year %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="month">Month</label>
        <select name="month" id="month">
          <% (monthOptions || []).forEach((month) => { %>
            <option value="<%= month %>" <%= String(month) === String(currentMonthName) ? 'selected' : '' %>><%= month %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="day">Day</label>
        <select name="day" id="day">
          <% (dayOptions || []).forEach((day) => { %>
            <option value="<%= day %>" <%= Number(day) === Number(todayDay) ? 'selected' : '' %>><%= day %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <button class="btn btn-primary" type="submit">Load Absent List</button>
      </div>
      <div>
        <button class="btn btn-print" type="button" onclick="window.print()">Print A4</button>
      </div>
    </form>

    <section class="content">
      <% if (groups && groups.length > 0) { %>
        <% groups.forEach((group) => { %>
          <article class="group-card">
            <div class="group-header">
              <div class="group-title">Class <%= group.studentClass || '-' %> <%= group.section ? '(' + group.section + ')' : '' %></div>
              <div class="group-count">Absent: <%= group.absentCount || 0 %></div>
            </div>
            <table>
              <thead>
                <tr>
                  <th style="width:70px">Roll</th>
                  <th>Student Name</th>
                </tr>
              </thead>
              <tbody>
                <% if (group.students && group.students.length > 0) { %>
                  <% group.students.forEach((student) => { %>
                    <tr>
                      <td><%= student.roll || '-' %></td>
                      <td>
                        <span><%= student.name || '-' %></span>
                        <% if (student.reason) { %>
                          <span class="reason">Reason: <%= student.reason %></span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="2">No absent students in this class.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </article>
        <% }) %>
      <% } else { %>
        <div class="empty">No absent students found for the selected date.</div>
      <% } %>
    </section>
  </div>
</body>
</html>
