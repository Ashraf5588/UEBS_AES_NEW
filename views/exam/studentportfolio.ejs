                            <%= subject %>
                            <div style="font-size: 0.75rem; color: #94a3b8; font-weight: 400;"><%= year %></div>
                         </div>
                         <div style="text-align: right;">
                            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= Math.round(prediction) %></div>
                            <div style="font-size: 0.7rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;"><%= predictionLabel %></div>
                         </div>
                      </div>
                      <% } %>
                      <% }) %>
                   <% }) %>
                </div>
             <% } %>

          </main>
       </div>

       <!-- Scripts for Charts -->
       <% if (hasRecords) { %>
          <script>
             {
                // Sort terminals for chart
                const termOrder = ['first', 'second', 'third', 'final'];
                const terminals = <%- JSON.stringify(Array.from(allTerminals)) %>.sort((a, b) => {
                   const lowerA = a.toLowerCase();
                   const lowerB = b.toLowerCase();
                   const indexA = termOrder.findIndex(t => lowerA.includes(t));
                   const indexB = termOrder.findIndex(t => lowerB.includes(t));
                   
                   const valA = indexA === -1 ? 999 : indexA;
                   const valB = indexB === -1 ? 999 : indexB;
                   
                   return valA - valB;
                });
                
                const subjectData = <%- JSON.stringify(subjectPerformance) %>;
                
                // Prepare datasets for Terminal Chart
                const datasets = Object.entries(subjectData).map(([subject, terms], index) => {
                   const data = terminals.map(t => terms[t] || 0);
                   const colors = ['#2563eb', '#ef4444', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899'];
                   return {
                      label: subject,
                      data: data,
                      borderColor: colors[index % colors.length],
                      backgroundColor: colors[index % colors.length],
                      tension: 0.3,
                      fill: false,
                      pointRadius: 4
                   };
                });

                const ctxTerm = document.getElementById('chart_term_<%= reg %>').getContext('2d');
                new Chart(ctxTerm, {
                   type: 'line',
                   data: {
                      labels: terminals,
                      datasets: datasets
                   },
                   options: {
                      responsive: true,
                      maintainAspectRatio: false,
                      plugins: {
                         legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } }
                      },
                      scales: { y: { beginAtZero: true } }
                   }
                });

                // Year Chart - Subject wise
                const years = <%- JSON.stringify(Array.from(allYears).sort()) %>;
                const subjectYearlyData = <%- JSON.stringify(subjectYearlyPerformance) %>;
                
                const yearDatasets = Object.entries(subjectYearlyData).map(([subject, yearData], index) => {
                   const data = years.map(y => yearData[y] || 0);
                   const colors = ['#2563eb', '#ef4444', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899'];
                   return {
                      label: subject,
                      data: data,
                      borderColor: colors[index % colors.length],
                      backgroundColor: colors[index % colors.length],
                      tension: 0.3,
                      fill: false,
                      pointRadius: 4
                   };
                });
                
                const ctxYear = document.getElementById('chart_year_<%= reg %>').getContext('2d');
                new Chart(ctxYear, {
                   type: 'line',
                   data: {
                      labels: years,
                      datasets: yearDatasets
                   },
                   options: {
                      responsive: true,
                      maintainAspectRatio: false,
                      plugins: {
                         legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } }
                      },
                      scales: { y: { beginAtZero: true } }
                   }
                });
             }
          </script>
       <% } %>

      <% }) %>
   <% } %>
<script>
   const rosterByReg = <%- JSON.stringify(rosterByReg || {}) %>;
   const studentCards = Array.from(document.querySelectorAll('.student-card'));
   const filterSearch = document.getElementById('filterSearch');
   const filterFamily = document.getElementById('filterFamily');
   const filterMedical = document.getElementById('filterMedical');
   const filterBehavior = document.getElementById('filterBehavior');
   const filterBlood = document.getElementById('filterBlood');
   const filterTv = document.getElementById('filterTv');
   const filterInternet = document.getElementById('filterInternet');
   const filterCount = document.getElementById('filterCount');

   function normalize(value) {
      return String(value || '').toLowerCase().trim();
   }

   function isEmptyValue(value) {
      const normalized = normalize(value);
      return !normalized || normalized === '-' || normalized === 'n/a' || normalized === 'na' || normalized === 'none';
   }

   function matchesYesNo(value, filterValue) {
      if (filterValue === 'any') return true;
      const empty = isEmptyValue(value);
      if (filterValue === 'yes') return !empty;
      if (filterValue === 'no') return empty;
      return true;
   }

   function applyPortfolioFilters() {
      if (!studentCards.length) return;
      const searchValue = normalize(filterSearch && filterSearch.value);
      const familyValue = normalize(filterFamily && filterFamily.value);
      const medicalValue = filterMedical ? filterMedical.value : 'any';
      const behaviorValue = filterBehavior ? filterBehavior.value : 'any';
      const bloodValue = normalize(filterBlood && filterBlood.value);
      const tvValue = filterTv ? filterTv.value : 'any';
      const internetValue = filterInternet ? filterInternet.value : 'any';

      let visibleCount = 0;

      studentCards.forEach((card) => {
         const data = card.dataset;
         const searchBlob = [
            data.name,
            data.reg,
            data.roll,
            data.father,
            data.mother,
            data.guardian
         ].map(normalize).join(' ');

         const familyBlob = [
            data.father,
            data.mother,
            data.guardian,
            data.fatherOcc,
            data.motherOcc,
            data.guardianOcc,
            data.income
         ].map(normalize).join(' ');

         const matchesSearch = !searchValue || searchBlob.includes(searchValue);
         const matchesFamily = !familyValue || familyBlob.includes(familyValue);
         const matchesMedical = matchesYesNo(data.medical, medicalValue);
         const matchesBehavior = matchesYesNo(data.behaviour, behaviorValue);
         const matchesBlood = !bloodValue || bloodValue === 'any' || normalize(data.blood) === bloodValue;
         const matchesTv = matchesYesNo(data.tv, tvValue);
         const matchesInternet = matchesYesNo(data.internet, internetValue);

         const visible = matchesSearch && matchesFamily && matchesMedical && matchesBehavior && matchesBlood && matchesTv && matchesInternet;
         card.style.display = visible ? '' : 'none';
         if (visible) visibleCount += 1;
      });

      if (filterCount) {
         filterCount.textContent = `${visibleCount} student${visibleCount === 1 ? '' : 's'} shown`;
      }
   }

   function resetPortfolioFilters() {
      if (filterSearch) filterSearch.value = '';
      if (filterFamily) filterFamily.value = '';
      if (filterMedical) filterMedical.value = 'any';
      if (filterBehavior) filterBehavior.value = 'any';
      if (filterBlood) filterBlood.value = 'any';
      if (filterTv) filterTv.value = 'any';
      if (filterInternet) filterInternet.value = 'any';
      applyPortfolioFilters();
   }

   if (filterSearch) filterSearch.addEventListener('input', applyPortfolioFilters);
   if (filterFamily) filterFamily.addEventListener('input', applyPortfolioFilters);
   if (filterMedical) filterMedical.addEventListener('change', applyPortfolioFilters);
   if (filterBehavior) filterBehavior.addEventListener('change', applyPortfolioFilters);
   if (filterBlood) filterBlood.addEventListener('change', applyPortfolioFilters);
   if (filterTv) filterTv.addEventListener('change', applyPortfolioFilters);
   if (filterInternet) filterInternet.addEventListener('change', applyPortfolioFilters);
   applyPortfolioFilters();

   function formatDateInput(value) {
      if (!value) return '';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '';
      return date.toISOString().slice(0, 10);
   }

   function setField(id, value) {
      const el = document.getElementById(id);
      if (!el) return;
      el.value = value || '';
   }

   function setRadio(name, value) {
      const radios = document.querySelectorAll(`input[name="${name}"]`);
      if (!radios.length) return;
      const normalized = String(value || '').toLowerCase();
      radios.forEach((radio) => {
         const radioValue = String(radio.value || '').toLowerCase();
         radio.checked = normalized === radioValue;
      });
   }

   function openInfoModal(reg) {
      const data = rosterByReg[reg] || {};
      setField('info_reg', reg);
      setField('info_name', data.name);
      setField('info_roll', data.roll);
      setField('info_class', data.studentClass);
      setField('info_section', data.section);
      setField('info_gender', data.gender);
      setField('info_dob', formatDateInput(data.dob));
      setField('info_class_started', formatDateInput(data.classStartedAt));
      setField('info_mother_tongue', data.mothersToungue);
      setField('info_previous_school', data.previousSchool);
      setField('info_father_name', data.fatherName);
      setField('info_father_occupation', data.fatheroccupation);
      setField('info_father_contact', data.fatherContact);
      setField('info_father_qualification', data.fatherqualification);
      setField('info_mother_name', data.motherName);
      setField('info_mother_occupation', data.motheroccupation);
      setField('info_mother_contact', data.motherContact);
      setField('info_mother_qualification', data.motherqualification);
      setField('info_guardian_name', data.otherguardianName);
      setField('info_guardian_occupation', data.otherguardianOccupation);
      setField('info_guardian_contact', data.otherguardianContact);
      setField('info_yearly_income', data.yearlyIncome);
      setField('info_blood_group', data.bloodGroup);
      setField('info_medical', Array.isArray(data.anyMedicalCondition) ? data.anyMedicalCondition.join(', ') : data.anyMedicalCondition);
      setField('info_behaviour', data.otherbehaviouralCondition);
      setField('info_mobile', data.numberofmobile);
      setRadio('tvatHome', data.tvatHome);
      setRadio('internetAtHome', data.internetAtHome);
      setField('info_fee_paid', data.feepaidduration);
      document.getElementById('infoModal').classList.add('is-open');
      document.getElementById('infoModal').setAttribute('aria-hidden', 'false');
   }

   function closeInfoModal() {
      const modal = document.getElementById('infoModal');
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
   }

   function addInformation(reg) {
      openInfoModal(reg);
   }

   document.getElementById('infoForm').addEventListener('submit', function (event) {
      event.preventDefault();
      const formData = new FormData(event.target);
      const payload = {};
      formData.forEach((value, key) => {
         payload[key] = value;
      });

      fetch('/studentportfolio/record', {
         method: 'POST',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify(payload)
      })
      .then((response) => response.json())
      .then((data) => {
         if (data.success) {
            alert('Student information saved.');
            closeInfoModal();
            window.location.reload();
         } else {
            alert(data.message || 'Failed to save student information.');
         }
      })
      .catch((error) => {
         console.error('Error:', error);
         alert('An error occurred while saving the information.');
      });
   });

   function addComplaint(reg) {
      const complaint = prompt("Enter your complaint or feedback for this student:");
      if (complaint) {
         // Send complaint to server (you can use fetch or AJAX)
         fetch('/addComplaint', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reg, complaint })
         })
         .then(response => response.json())
         .then(data => {
            if (data.success) {
               alert("Complaint added successfully!");
            } else {
               alert("Failed to add complaint. Please try again.");
            }
         })
         .catch(error => {
            console.error('Error:', error);
            alert("An error occurred while adding the complaint.");
         });
      }
   }
</script>
