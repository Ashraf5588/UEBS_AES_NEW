                                  <tr>
                                     <% sortedTerms.forEach(term => { 
                                          const data = termdata[term];
                                     %>
                                        <td class="mark-cell <%= data.theory < 35 ? 'mark-fail' : 'mark-pass' %>">
                                           <%= data.theory %>
                                        </td>
                                     <% }) %>
