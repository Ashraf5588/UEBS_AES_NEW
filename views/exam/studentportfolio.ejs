<div id="complaintModal" class="modal-backdrop" aria-hidden="true">
   <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="complaintModalTitle">
      <div class="modal-header">
         <div class="modal-title" id="complaintModalTitle">Add Complaint</div>
         <button type="button" class="btn-secondary" onclick="closeComplaintModal()">Close</button>
      </div>
      <form id="complaintForm">
         <div class="modal-body" style="grid-template-columns: 1fr;">
            <div class="modal-field">
               <label for="complaint_reg">Reg No</label>
               <input id="complaint_reg" name="reg" type="text" readonly />
            </div>
            <div class="modal-field">
               <label for="complaint_reason">Complaint / Feedback</label>
               <textarea id="complaint_reason" name="complaint" placeholder="Write complaint details..."></textarea>
            </div>
            <div class="modal-field">
               <label>Complaint Images (Multiple)</label>
               <div class="upload-box">
                  <div class="upload-controls">
                     <button type="button" id="complaint_pick_btn">Upload Images</button>
                     <button type="button" id="complaint_capture_btn" class="capture-btn">Capture Image</button>
                  </div>
                  <input id="complaint_images_picker" class="visually-hidden" type="file" accept="image/*" multiple />
                  <input id="complaint_images_capture" class="visually-hidden" type="file" accept="image/*" capture="environment" />
                  <div id="complaint_upload_status" class="upload-status"></div>
                  <div id="complaint_upload_preview" class="upload-preview"></div>
               </div>
            </div>
         </div>
         <div class="modal-footer">
            <button type="button" class="btn-secondary" onclick="closeComplaintModal()">Cancel</button>
            <button type="submit">Save Complaint</button>
         </div>
      </form>
   </div>
</div>

<script>
   const rosterByReg = <%- JSON.stringify(rosterByReg || {}) %>;
   const studentCards = Array.from(document.querySelectorAll('.student-card'));
   const filterSearch = document.getElementById('filterSearch');
   const filterFamily = document.getElementById('filterFamily');
   const filterMedicalChecks = Array.from(document.querySelectorAll('.filter-medical-check'));
   const filterParentVisitChecks = Array.from(document.querySelectorAll('.filter-parent-visit'));
   const filterParentViewChecks = Array.from(document.querySelectorAll('.filter-parent-view'));
   const filterTvChecks = Array.from(document.querySelectorAll('.filter-tv'));
   const filterInternetChecks = Array.from(document.querySelectorAll('.filter-internet'));
   const filterBlood = document.getElementById('filterBlood');
   const filterCount = document.getElementById('filterCount');
   const complaintForm = document.getElementById('complaintForm');
   const complaintImageInput = document.getElementById('complaint_images_picker');
   const complaintCaptureInput = document.getElementById('complaint_images_capture');
   const complaintPickButton = document.getElementById('complaint_pick_btn');
   const complaintCaptureButton = document.getElementById('complaint_capture_btn');
   const complaintUploadStatus = document.getElementById('complaint_upload_status');
   const complaintUploadPreview = document.getElementById('complaint_upload_preview');
   let complaintImageUrls = [];

   function normalize(value) {
      return String(value || '').toLowerCase().trim();
   }

   function isEmptyValue(value) {
      const normalized = normalize(value);
      return !normalized || normalized === '-' || normalized === 'n/a' || normalized === 'na' || normalized === 'none';
   }

   function matchesYesNo(value, filterValue) {
      if (filterValue === 'any') return true;
      const empty = isEmptyValue(value);
      if (filterValue === 'yes') return !empty;
      if (filterValue === 'no') return empty;
      return true;
   }

   function isYesValue(value) {
      const normalized = normalize(value);
      return normalized === 'yes' || normalized === 'true' || normalized === '1';
   }

   function getCheckedValues(elements) {
      return elements.filter((el) => el.checked).map((el) => normalize(el.value));
   }

   function applyPortfolioFilters() {
      if (!studentCards.length) return;
      const searchValue = normalize(filterSearch && filterSearch.value);
      const familyValue = normalize(filterFamily && filterFamily.value);
      const bloodValue = normalize(filterBlood && filterBlood.value);
      const selectedMedical = getCheckedValues(filterMedicalChecks);
      const selectedParentVisit = getCheckedValues(filterParentVisitChecks);
      const selectedParentView = getCheckedValues(filterParentViewChecks);
      const selectedTv = getCheckedValues(filterTvChecks);
      const selectedInternet = getCheckedValues(filterInternetChecks);

      let visibleCount = 0;

      studentCards.forEach((card) => {
         const data = card.dataset;
         const searchBlob = [
            data.name,
            data.reg,
            data.roll,
            data.father,
            data.mother,
            data.guardian
         ].map(normalize).join(' ');

         const familyBlob = [
            data.father,
            data.mother,
            data.guardian,
            data.fatherOcc,
            data.motherOcc,
            data.guardianOcc,
            data.income
         ].map(normalize).join(' ');

         const matchesSearch = !searchValue || searchBlob.includes(searchValue);
         const matchesFamily = !familyValue || familyBlob.includes(familyValue);
         const matchesBlood = !bloodValue || bloodValue === 'any' || normalize(data.blood) === bloodValue;

         const hasBehaviour = !isEmptyValue(data.behaviour);
         const medicalChecks = {
            eye: isYesValue(data.eye),
            ear: isYesValue(data.ear),
            hair: isYesValue(data.hair),
            behaviour: hasBehaviour
         };

         const matchesMedical = selectedMedical.every((key) => medicalChecks[key]);
         const matchesParentVisit = !selectedParentVisit.length || selectedParentVisit.includes(normalize(data.parentVisit));
         const matchesParentView = !selectedParentView.length || selectedParentView.includes(normalize(data.parentView));
         const tvNormalized = isYesValue(data.tv) ? 'yes' : 'no';
         const internetNormalized = isYesValue(data.internet) ? 'yes' : 'no';
         const matchesTv = !selectedTv.length || selectedTv.includes(tvNormalized);
         const matchesInternet = !selectedInternet.length || selectedInternet.includes(internetNormalized);

         const visible = matchesSearch
            && matchesFamily
            && matchesMedical
            && matchesBlood
            && matchesParentVisit
            && matchesParentView
            && matchesTv
            && matchesInternet;
         card.style.display = visible ? '' : 'none';
         if (visible) visibleCount += 1;
      });

      if (filterCount) {
         filterCount.textContent = `${visibleCount} student${visibleCount === 1 ? '' : 's'} shown`;
      }
   }

   function resetPortfolioFilters() {
      if (filterSearch) filterSearch.value = '';
      if (filterFamily) filterFamily.value = '';
      filterMedicalChecks.forEach((el) => { el.checked = false; });
      filterParentVisitChecks.forEach((el) => { el.checked = false; });
      filterParentViewChecks.forEach((el) => { el.checked = false; });
      filterTvChecks.forEach((el) => { el.checked = false; });
      filterInternetChecks.forEach((el) => { el.checked = false; });
      if (filterBlood) filterBlood.value = 'any';
      applyPortfolioFilters();
   }

   if (filterSearch) filterSearch.addEventListener('input', applyPortfolioFilters);
   if (filterFamily) filterFamily.addEventListener('input', applyPortfolioFilters);
   filterMedicalChecks.forEach((el) => el.addEventListener('change', applyPortfolioFilters));
   filterParentVisitChecks.forEach((el) => el.addEventListener('change', applyPortfolioFilters));
   filterParentViewChecks.forEach((el) => el.addEventListener('change', applyPortfolioFilters));
   filterTvChecks.forEach((el) => el.addEventListener('change', applyPortfolioFilters));
   filterInternetChecks.forEach((el) => el.addEventListener('change', applyPortfolioFilters));
   if (filterBlood) filterBlood.addEventListener('change', applyPortfolioFilters);
   applyPortfolioFilters();

   function formatDateInput(value) {
      if (!value) return '';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '';
      return date.toISOString().slice(0, 10);
   }

   function setField(id, value) {
      const el = document.getElementById(id);
      if (!el) return;
      el.value = value || '';
   }

   function setRadio(name, value, fallbackValue) {
      const radios = document.querySelectorAll(`input[name="${name}"]`);
      if (!radios.length) return;
      const normalized = String(value || '').toLowerCase();
      let matched = false;
      radios.forEach((radio) => {
         const radioValue = String(radio.value || '').toLowerCase();
         const shouldCheck = normalized && normalized === radioValue;
         radio.checked = shouldCheck;
         if (shouldCheck) matched = true;
      });

      if (!matched && fallbackValue !== undefined) {
         const fallbackNormalized = String(fallbackValue).toLowerCase();
         radios.forEach((radio) => {
            const radioValue = String(radio.value || '').toLowerCase();
            radio.checked = radioValue === fallbackNormalized;
         });
      }
   }

   function toBoolean(value, fallback) {
      if (value === true || value === false) return value;
      const normalized = String(value || '').toLowerCase().trim();
      if (normalized === 'true' || normalized === 'yes' || normalized === '1') return true;
      if (normalized === 'false' || normalized === 'no' || normalized === '0') return false;
      return fallback;
   }

   function setToggle(id, value, fallbackChecked) {
      const el = document.getElementById(id);
      if (!el) return;
      const next = toBoolean(value, fallbackChecked);
      el.checked = !!next;
   }

   function openInfoModal(reg) {
      const data = rosterByReg[reg] || {};
      setField('info_reg', reg);
      setField('info_name', data.name);
      setField('info_roll', data.roll);
      setField('info_class', data.studentClass);
      setField('info_section', data.section);
      setField('info_gender', data.gender);
      setField('info_age', data.age);
      setField('info_dob', formatDateInput(data.dob));
      setField('info_class_started', formatDateInput(data.classStartedAt));
      setField('info_mother_tongue', data.mothersToungue);
      setField('info_previous_school', data.previousSchool);
      setField('info_father_name', data.fatherName);
      setField('info_father_occupation', data.fatheroccupation);
      setField('info_father_contact', data.fatherContact);
      setField('info_father_qualification', data.fatherqualification);
      setField('info_mother_name', data.motherName);
      setField('info_mother_occupation', data.motheroccupation);
      setField('info_mother_contact', data.motherContact);
      setField('info_mother_qualification', data.motherqualification);
      setField('info_guardian_name', data.otherguardianName);
      setField('info_guardian_occupation', data.otherguardianOccupation);
      setField('info_guardian_contact', data.otherguardianContact);
      setField('info_yearly_income', data.yearlyIncome);
      setField('info_blood_group', data.bloodGroup);
      setField('info_height', data.height);
      setField('info_weight', data.weight);
      setField('info_medical', Array.isArray(data.anyMedicalCondition) ? data.anyMedicalCondition.join(', ') : data.anyMedicalCondition);
      setField('info_behaviour', data.otherbehaviouralCondition);
      setToggle('toggle_eyeproblem', data.eyeproblem, false);
      setToggle('toggle_earproblem', data.earproblem, false);
      setToggle('toggle_hairproblem', data.hairproblem, false);
      const liveWithParents = !(toBoolean(data.liveWithFather, true) === false || toBoolean(data.liveWithMother, true) === false);
      setToggle('toggle_livewithparents', liveWithParents, true);
      setToggle('toggle_parentview', String(data.parentViewTowardsSchool || 'positive').toLowerCase() !== 'negative', true);
      setRadio('parentVisitFrequency', data.parentVisitFrequency, 'occasional');
      setField('info_mobile', data.numberofmobile);
      setToggle('toggle_tvathome', data.tvatHome, true);
      setToggle('toggle_internetathome', data.internetAtHome, true);
      setField('info_fee_paid', data.feepaidduration);
      document.getElementById('infoModal').classList.add('is-open');
      document.getElementById('infoModal').setAttribute('aria-hidden', 'false');
   }

   function closeInfoModal() {
      const modal = document.getElementById('infoModal');
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
   }

   function addInformation(reg) {
      openInfoModal(reg);
   }

   function setComplaintUploadStatus(message, color) {
      if (!complaintUploadStatus) return;
      complaintUploadStatus.textContent = message || '';
      complaintUploadStatus.style.color = color || '#64748b';
   }

   function renderComplaintPreview() {
      if (!complaintUploadPreview) return;
      complaintUploadPreview.innerHTML = '';

      complaintImageUrls.forEach((url) => {
         const wrapper = document.createElement('div');
         wrapper.className = 'upload-preview-item';

         const img = document.createElement('img');
         img.src = url;
         img.alt = 'Complaint image';

         const removeBtn = document.createElement('button');
         removeBtn.type = 'button';
         removeBtn.className = 'upload-remove-btn';
         removeBtn.innerHTML = 'x';
         removeBtn.addEventListener('click', () => {
            complaintImageUrls = complaintImageUrls.filter((item) => item !== url);
            renderComplaintPreview();
         });

         wrapper.appendChild(img);
         wrapper.appendChild(removeBtn);
         complaintUploadPreview.appendChild(wrapper);
      });
   }

   async function uploadComplaintImages(files) {
      if (!files || !files.length) return;
      const formData = new FormData();
      Array.from(files).forEach((file) => formData.append('image', file));

      setComplaintUploadStatus(`Uploading ${files.length} image(s)...`, '#0369a1');

      try {
         const response = await fetch('/upload-project-image', {
            method: 'POST',
            body: formData
         });
         const result = await response.json();

         if (!response.ok || !result.success) {
            throw new Error(result.message || 'Image upload failed');
         }

         const urls = Array.isArray(result.filePaths)
            ? result.filePaths
            : (result.filePath ? [result.filePath] : []);

         complaintImageUrls = complaintImageUrls.concat(urls);
         renderComplaintPreview();
         setComplaintUploadStatus('Images uploaded.', '#16a34a');
      } catch (error) {
         console.error('Complaint image upload error:', error);
         setComplaintUploadStatus('Image upload failed.', '#dc2626');
      }
   }

   function openComplaintModal(reg) {
      setField('complaint_reg', reg);
      setField('complaint_reason', '');
      complaintImageUrls = [];
      renderComplaintPreview();
      setComplaintUploadStatus('');

      const modal = document.getElementById('complaintModal');
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
   }

   function closeComplaintModal() {
      const modal = document.getElementById('complaintModal');
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
   }

   document.getElementById('infoForm').addEventListener('submit', function (event) {
      event.preventDefault();
      const formData = new FormData(event.target);
      const payload = {};
      formData.forEach((value, key) => {
         payload[key] = value;
      });

      const eyeProblem = document.getElementById('toggle_eyeproblem').checked;
      const earProblem = document.getElementById('toggle_earproblem').checked;
      const hairProblem = document.getElementById('toggle_hairproblem').checked;
      const liveWithParents = document.getElementById('toggle_livewithparents').checked;
      const parentViewPositive = document.getElementById('toggle_parentview').checked;
      const tvAtHome = document.getElementById('toggle_tvathome').checked;
      const internetAtHome = document.getElementById('toggle_internetathome').checked;

      payload.eyeproblem = eyeProblem;
      payload.earproblem = earProblem;
      payload.hairproblem = hairProblem;
      payload.liveWithFather = liveWithParents;
      payload.liveWithMother = liveWithParents;
      payload.parentViewTowardsSchool = parentViewPositive ? 'positive' : 'negative';
      payload.tvatHome = tvAtHome ? 'Yes' : 'No';
      payload.internetAtHome = internetAtHome ? 'Yes' : 'No';

      fetch('/studentportfolio/record', {
         method: 'POST',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify(payload)
      })
      .then((response) => response.json())
      .then((data) => {
         if (data.success) {
            alert('Student information saved.');
            closeInfoModal();
            window.location.reload();
         } else {
            alert(data.message || 'Failed to save student information.');
         }
      })
      .catch((error) => {
         console.error('Error:', error);
         alert('An error occurred while saving the information.');
      });
   });

   function addComplaint(reg) {
      openComplaintModal(reg);
   }

   if (complaintImageInput) {
      complaintImageInput.addEventListener('change', async function (event) {
         await uploadComplaintImages(event.target.files);
         event.target.value = '';
      });
   }

   if (complaintCaptureInput) {
      complaintCaptureInput.addEventListener('change', async function (event) {
         await uploadComplaintImages(event.target.files);
         event.target.value = '';
      });
   }

   if (complaintPickButton && complaintImageInput) {
      complaintPickButton.addEventListener('click', function () {
         complaintImageInput.click();
      });
   }

   if (complaintCaptureButton && complaintCaptureInput) {
      complaintCaptureButton.addEventListener('click', function () {
         complaintCaptureInput.click();
      });
   }

   if (complaintForm) {
      complaintForm.addEventListener('submit', function (event) {
         event.preventDefault();
         const reg = (document.getElementById('complaint_reg').value || '').trim();
         const complaint = (document.getElementById('complaint_reason').value || '').trim();

         if (!reg || !complaint) {
            alert('Reg and complaint are required.');
            return;
         }

         fetch('/addComplaint', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reg, complaint, images: complaintImageUrls })
         })
         .then(response => response.json())
         .then((data) => {
            if (data.success) {
               alert('Complaint added successfully!');
               closeComplaintModal();
               window.location.reload();
            } else {
               alert(data.message || 'Failed to add complaint. Please try again.');
            }
         })
         .catch((error) => {
            console.error('Error:', error);
            alert('An error occurred while adding the complaint.');
         });
      });
   }
</script>
</body>
</html>